#!/usr/bin/env tclsh

set testdir [file dirname $argv0]

# Signal to tester.tcl's finish_test that individual .test files are being
# sourced as part of an aggregate run; they should not print their own
# summaries or exit.
set ALL_TESTS 1

source $testdir/select1.test
# FIXME: source $testdir/select2.test
# FIXME: source $testdir/select3.test
# FIXME: source $testdir/select4.test
# FIXME: source $testdir/select5.test
