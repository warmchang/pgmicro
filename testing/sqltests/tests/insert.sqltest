    |1
    |6
}

@cross-check-integrity
test unique_insert_with_pkey {
    CREATE TABLE t2 (x INTEGER PRIMARY KEY, y INTEGER UNIQUE);
    INSERT INTO t2 (y) VALUES (1);
    INSERT INTO t2 (y) VALUES (6);
    SELECT * FROM t2;
}
expect {
    1|1
    2|6
}

