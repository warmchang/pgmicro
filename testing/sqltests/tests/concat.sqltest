@database :default:
@database :default-no-rowidalias:

#!/usr/bin/env tclsh
test concat {
    SELECT 'Hello' || ' ' || 'World';
}
expect {
    Hello World
}

test concat-2 {
    SELECT 'Hello' || NULL;
}
expect {
}

test concat-3 {
    SELECT 'Hello' || NULL;
}
expect {
}

test concat-4 {
    SELECT 'A good ' || name FROM products WHERE name = 'hat';
}
expect {
    A good hat
}

test concat-4-2 {
    SELECT 'A good ' || name FROM products WHERE name = 'watch';
}
expect {
}

test concat-blob {
    SELECT hex(x'01' || x'02');
}
expect {
    0102
}

test concat-no-args-error {
    SELECT concat();
}
expect error {
    wrong number of arguments to function concat()
}

test concat-ws-no-args-error {
    SELECT concat_ws();
}
expect error {
    wrong number of arguments to function concat_ws()
}

test concat-ws-one-arg-error {
    SELECT concat_ws(',');
}
expect error {
    wrong number of arguments to function concat_ws()
}
