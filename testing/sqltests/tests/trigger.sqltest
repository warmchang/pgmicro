    CREATE TABLE counter(n INTEGER);
    INSERT INTO counter VALUES(0);
    INSERT INTO t1 VALUES(1);
    CREATE TRIGGER tr1 AFTER INSERT ON t1 BEGIN
      UPDATE counter SET n = (SELECT max(id) FROM t1);
    END;
    INSERT INTO t1 VALUES(2);
