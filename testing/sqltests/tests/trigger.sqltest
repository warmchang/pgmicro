}

# RAISE(ROLLBACK, expr) with expression error message
test trigger-raise-rollback-expr {
    CREATE TABLE raise_expr_t3 (a INTEGER);
    CREATE TRIGGER raise_expr_tr3 BEFORE INSERT ON raise_expr_t3 WHEN NEW.a < 0 BEGIN
        SELECT RAISE(ROLLBACK, 'rollback: ' || NEW.a);
    END;
    INSERT INTO raise_expr_t3 VALUES(-1);
}
expect error {
    rollback: -1
}

# RAISE with expression using CASE
test trigger-raise-expr-case {
    CREATE TABLE raise_expr_t4 (a INTEGER);
    CREATE TRIGGER raise_expr_tr4 BEFORE INSERT ON raise_expr_t4 WHEN NEW.a < 0 BEGIN
        SELECT RAISE(ABORT, CASE WHEN NEW.a < -10 THEN 'very bad' ELSE 'bad' END);
    END;
    INSERT INTO raise_expr_t4 VALUES(-5);
}
expect error {
    bad
}

# Bare column reference in trigger WHEN clause should error
# SQLite rejects bare column names in WHEN clauses; they must be
# qualified with NEW or OLD.
@cross-check-integrity
test trigger-when-bare-column-error {
    CREATE TABLE t_bare_when (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TRIGGER trg_bare_when AFTER INSERT ON t_bare_when FOR EACH ROW WHEN a BEGIN SELECT 1; END;
    INSERT INTO t_bare_when (a, b) VALUES (1, 'hello');
}
expect error {
    no such column: a
}

# regression test for https://github.com/tursodatabase/turso/issues/5858
@cross-check-integrity
test trigger-when-between-bug {
    CREATE TABLE t202 (a INTEGER);
    CREATE TABLE log202 (val INTEGER);
    CREATE TRIGGER tr202 AFTER INSERT ON t202
    WHEN NEW.a BETWEEN 1 AND 10 BEGIN
        INSERT INTO log202 VALUES (NEW.a);
    END;
    INSERT INTO t202 VALUES (5);
    INSERT INTO t202 VALUES (50);
    SELECT * FROM log202;
}
expect {
    5
}

# regression test for https://github.com/tursodatabase/turso/issues/5859
@cross-check-integrity
test trigger-update-pk-change-bug {
    CREATE TABLE t210 (a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE log210 (old_a INTEGER, new_a INTEGER);
    INSERT INTO t210 VALUES (1, 'hello');
    CREATE TRIGGER tr210 BEFORE UPDATE ON t210 BEGIN
        INSERT INTO log210 VALUES (OLD.a, NEW.a);
    END;
    UPDATE t210 SET a = 100 WHERE a = 1;
    SELECT * FROM log210;
}
expect {
    1|100
}

# RETURNING is not allowed in trigger bodies (SQLite compatibility)
test trigger-returning-insert-rejected {
    CREATE TABLE tret(a);
    CREATE TABLE other_ret(b);
    CREATE TRIGGER tr_ret AFTER INSERT ON tret BEGIN
        INSERT INTO other_ret VALUES(NEW.a * 10) RETURNING *;
    END;
}
expect error {
    RETURNING
}

test trigger-returning-update-rejected {
    CREATE TABLE tret2(a);
    CREATE TABLE other_ret2(b);
    CREATE TRIGGER tr_ret2 AFTER INSERT ON tret2 BEGIN
        UPDATE other_ret2 SET b = 1 RETURNING *;
    END;
}
expect error {
    RETURNING
}

test trigger-returning-delete-rejected {
    CREATE TABLE tret3(a);
    CREATE TABLE other_ret3(b);
    CREATE TRIGGER tr_ret3 AFTER INSERT ON tret3 BEGIN
        DELETE FROM other_ret3 RETURNING *;
    END;
}
expect error {
    RETURNING
}

# NOT IN (SELECT ...) subquery in WHEN clause
@cross-check-integrity
test trigger-when-not-in-subquery {
    CREATE TABLE t_src(a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE t_lookup(id INTEGER PRIMARY KEY, name TEXT);
    CREATE TABLE t_log(msg TEXT);
    INSERT INTO t_lookup VALUES(1, 'alice');
    INSERT INTO t_lookup VALUES(2, 'bob');
    CREATE TRIGGER tr_not_in AFTER INSERT ON t_src
        WHEN NEW.a NOT IN (SELECT id FROM t_lookup)
    BEGIN
        INSERT INTO t_log VALUES('new id: ' || NEW.a);
    END;
    INSERT INTO t_src VALUES(1, 'exists');
    INSERT INTO t_src VALUES(3, 'new');
    INSERT INTO t_src VALUES(2, 'exists too');
    INSERT INTO t_src VALUES(5, 'also new');
    SELECT * FROM t_log ORDER BY rowid;
}
expect {
    new id: 3
    new id: 5
}

# IN (SELECT ...) subquery in WHEN clause
@cross-check-integrity
test trigger-when-in-subquery {
    CREATE TABLE t_in_src(a INTEGER PRIMARY KEY, b TEXT);
    CREATE TABLE t_in_lookup(id INTEGER PRIMARY KEY);
    CREATE TABLE t_in_log(msg TEXT);
    INSERT INTO t_in_lookup VALUES(10);
    INSERT INTO t_in_lookup VALUES(20);
    CREATE TRIGGER tr_in AFTER INSERT ON t_in_src
        WHEN NEW.a IN (SELECT id FROM t_in_lookup)
    BEGIN
        INSERT INTO t_in_log VALUES('matched: ' || NEW.a);
    END;
    INSERT INTO t_in_src VALUES(10, 'yes');
    INSERT INTO t_in_src VALUES(15, 'no');
    INSERT INTO t_in_src VALUES(20, 'yes');
    SELECT * FROM t_in_log ORDER BY rowid;
}
expect {
    matched: 10
    matched: 20
}

# EXISTS subquery in WHEN clause (correlated)
@cross-check-integrity
test trigger-when-exists-correlated {
    CREATE TABLE t_ex_src(a INTEGER PRIMARY KEY, val INTEGER);
    CREATE TABLE t_ex_ref(id INTEGER PRIMARY KEY, threshold INTEGER);
    CREATE TABLE t_ex_log(msg TEXT);
    INSERT INTO t_ex_ref VALUES(1, 50);
    INSERT INTO t_ex_ref VALUES(2, 100);
    CREATE TRIGGER tr_exists AFTER INSERT ON t_ex_src
        WHEN EXISTS (SELECT 1 FROM t_ex_ref WHERE threshold < NEW.val)
    BEGIN
        INSERT INTO t_ex_log VALUES('val exceeds some threshold: ' || NEW.val);
    END;
    INSERT INTO t_ex_src VALUES(1, 30);
    INSERT INTO t_ex_src VALUES(2, 75);
    INSERT INTO t_ex_src VALUES(3, 150);
    SELECT * FROM t_ex_log ORDER BY rowid;
}
expect {
    val exceeds some threshold: 75
    val exceeds some threshold: 150
}

# NOT EXISTS subquery in WHEN clause
@cross-check-integrity
test trigger-when-not-exists {
    CREATE TABLE t_nex_src(a INTEGER PRIMARY KEY, category TEXT);
    CREATE TABLE t_nex_blocked(cat TEXT);
    CREATE TABLE t_nex_log(msg TEXT);
    INSERT INTO t_nex_blocked VALUES('spam');
    INSERT INTO t_nex_blocked VALUES('junk');
    CREATE TRIGGER tr_not_exists BEFORE INSERT ON t_nex_src
        WHEN NOT EXISTS (SELECT 1 FROM t_nex_blocked WHERE cat = NEW.category)
    BEGIN
        INSERT INTO t_nex_log VALUES('accepted: ' || NEW.category);
    END;
    INSERT INTO t_nex_src VALUES(1, 'good');
    INSERT INTO t_nex_src VALUES(2, 'spam');
    INSERT INTO t_nex_src VALUES(3, 'great');
    INSERT INTO t_nex_src VALUES(4, 'junk');
    SELECT * FROM t_nex_log ORDER BY rowid;
}
expect {
    accepted: good
    accepted: great
}

# Scalar subquery in WHEN clause
@cross-check-integrity
test trigger-when-scalar-subquery {
    CREATE TABLE t_sc_src(a INTEGER PRIMARY KEY, val INTEGER);
    CREATE TABLE t_sc_config(threshold INTEGER);
    CREATE TABLE t_sc_log(msg TEXT);
    INSERT INTO t_sc_config VALUES(10);
    CREATE TRIGGER tr_scalar AFTER INSERT ON t_sc_src
        WHEN NEW.val > (SELECT threshold FROM t_sc_config LIMIT 1)
    BEGIN
        INSERT INTO t_sc_log VALUES('over threshold: ' || NEW.val);
    END;
    INSERT INTO t_sc_src VALUES(1, 5);
    INSERT INTO t_sc_src VALUES(2, 15);
    INSERT INTO t_sc_src VALUES(3, 8);
    INSERT INTO t_sc_src VALUES(4, 20);
    SELECT * FROM t_sc_log ORDER BY rowid;
}
expect {
    over threshold: 15
    over threshold: 20
}

# DELETE trigger with OLD in WHEN subquery
@cross-check-integrity
test trigger-when-subquery-old-ref {
    CREATE TABLE t_del_src(a INTEGER PRIMARY KEY, val INTEGER);
    CREATE TABLE t_del_protected(id INTEGER PRIMARY KEY);
    CREATE TABLE t_del_log(msg TEXT);
    INSERT INTO t_del_protected VALUES(1);
    INSERT INTO t_del_protected VALUES(3);
    INSERT INTO t_del_src VALUES(1, 10);
    INSERT INTO t_del_src VALUES(2, 20);
    INSERT INTO t_del_src VALUES(3, 30);
    CREATE TRIGGER tr_del_protect BEFORE DELETE ON t_del_src
        WHEN OLD.a IN (SELECT id FROM t_del_protected)
    BEGIN
        INSERT INTO t_del_log VALUES('attempted delete of protected id: ' || OLD.a);
    END;
    DELETE FROM t_del_src WHERE a = 1;
    DELETE FROM t_del_src WHERE a = 2;
    DELETE FROM t_del_src WHERE a = 3;
    SELECT * FROM t_del_log ORDER BY rowid;
}
expect {
    attempted delete of protected id: 1
    attempted delete of protected id: 3
}

# UPDATE trigger with WHEN subquery using both OLD and NEW
@cross-check-integrity
test trigger-when-subquery-update-old-new {
    CREATE TABLE t_upd_src(a INTEGER PRIMARY KEY, val INTEGER);
    CREATE TABLE t_upd_limits(id INTEGER PRIMARY KEY, max_val INTEGER);
    CREATE TABLE t_upd_log(msg TEXT);
    INSERT INTO t_upd_limits VALUES(1, 100);
    INSERT INTO t_upd_limits VALUES(2, 50);
    INSERT INTO t_upd_src VALUES(1, 10);
    INSERT INTO t_upd_src VALUES(2, 20);
    CREATE TRIGGER tr_upd_check AFTER UPDATE ON t_upd_src
        WHEN NEW.val > (SELECT max_val FROM t_upd_limits WHERE id = NEW.a)
    BEGIN
        INSERT INTO t_upd_log VALUES('exceeded limit for id ' || NEW.a || ': ' || NEW.val);
    END;
    UPDATE t_upd_src SET val = 50 WHERE a = 1;
    UPDATE t_upd_src SET val = 200 WHERE a = 1;
    UPDATE t_upd_src SET val = 30 WHERE a = 2;
    UPDATE t_upd_src SET val = 60 WHERE a = 2;
    SELECT * FROM t_upd_log ORDER BY rowid;
}
expect {
    exceeded limit for id 1: 200
    exceeded limit for id 2: 60
}

# https://github.com/tursodatabase/turso/issues/3985
# NEW.rowid_alias in BEFORE INSERT trigger should be -1 when auto-generated
test trigger-before-insert-rowid-alias-auto-neg1 {
    CREATE TABLE t_bi1(id INTEGER PRIMARY KEY, val TEXT);
    CREATE TABLE log_bi1(new_id INTEGER);
    CREATE TRIGGER tr_bi1 BEFORE INSERT ON t_bi1
    BEGIN
      INSERT INTO log_bi1 VALUES(NEW.id);
    END;
    INSERT INTO t_bi1(val) VALUES('hello');
    SELECT * FROM log_bi1;
    SELECT * FROM t_bi1;
}
expect {
    -1
    1|hello
}

# NEW.rowid_alias is -1 for auto but real value for explicit in BEFORE INSERT
test trigger-before-insert-rowid-alias-explicit-vs-auto {
    CREATE TABLE t_bi2(id INTEGER PRIMARY KEY, val TEXT);
    CREATE TABLE log_bi2(new_id INTEGER);
    CREATE TRIGGER tr_bi2 BEFORE INSERT ON t_bi2
    BEGIN
      INSERT INTO log_bi2 VALUES(NEW.id);
    END;
    INSERT INTO t_bi2(id, val) VALUES(42, 'explicit');
    INSERT INTO t_bi2(val) VALUES('auto');
    INSERT INTO t_bi2(id, val) VALUES(100, 'explicit2');
    SELECT * FROM log_bi2;
}
expect {
    42
    -1
    100
}

# NEW.rowid_alias in BEFORE INSERT used in expression
test trigger-before-insert-rowid-alias-in-expr {
    CREATE TABLE t_bi3(id INTEGER PRIMARY KEY, val TEXT);
    CREATE TABLE log_bi3(msg TEXT);
    CREATE TRIGGER tr_bi3 BEFORE INSERT ON t_bi3
    BEGIN
      INSERT INTO log_bi3 VALUES('id=' || CAST(NEW.id AS TEXT));
    END;
    INSERT INTO t_bi3(val) VALUES('hello');
    SELECT * FROM log_bi3;
}
expect {
    id=-1
}

# Multiple auto-generated inserts all get -1 in BEFORE INSERT trigger
test trigger-before-insert-rowid-alias-multiple {
    CREATE TABLE t_bi4(id INTEGER PRIMARY KEY, val TEXT);
    CREATE TABLE log_bi4(new_id INTEGER);
    CREATE TRIGGER tr_bi4 BEFORE INSERT ON t_bi4
    BEGIN
      INSERT INTO log_bi4 VALUES(NEW.id);
    END;
    INSERT INTO t_bi4(val) VALUES('a');
    INSERT INTO t_bi4(val) VALUES('b');
    INSERT INTO t_bi4(val) VALUES('c');
    SELECT * FROM log_bi4;
    SELECT * FROM t_bi4;
}
expect {
    -1
    -1
    -1
    1|a
    2|b
    3|c
}

# BEFORE INSERT WHEN clause can match on NEW.rowid_alias = -1
test trigger-before-insert-rowid-alias-when-neg1 {
    CREATE TABLE t_bi5(id INTEGER PRIMARY KEY, val TEXT);
    CREATE TABLE log_bi5(msg TEXT);
    CREATE TRIGGER tr_bi5 BEFORE INSERT ON t_bi5 WHEN NEW.id = -1
    BEGIN
      INSERT INTO log_bi5 VALUES('auto-generated rowid');
    END;
    INSERT INTO t_bi5(val) VALUES('auto');
    INSERT INTO t_bi5(id, val) VALUES(5, 'explicit');
    SELECT * FROM log_bi5;
}
expect {
    auto-generated rowid
}

# Explicit NULL for rowid alias in BEFORE INSERT trigger should also get -1
test trigger-before-insert-rowid-alias-explicit-null {
    CREATE TABLE t_bi6(id INTEGER PRIMARY KEY, val TEXT);
    CREATE TABLE log_bi6(new_id INTEGER);
    CREATE TRIGGER tr_bi6 BEFORE INSERT ON t_bi6
    BEGIN
      INSERT INTO log_bi6 VALUES(NEW.id);
    END;
    INSERT INTO t_bi6(id, val) VALUES(NULL, 'null_explicit');
    INSERT INTO t_bi6(id, val) VALUES(10, 'ten');
    INSERT INTO t_bi6 VALUES(NULL, 'null_implicit');
    SELECT * FROM log_bi6;
    SELECT * FROM t_bi6 ORDER BY id;
}
expect {
    -1
    10
    -1
    1|null_explicit
    10|ten
    11|null_implicit
}

# AUTOINCREMENT must stay monotonic across trigger side effects on the same table.
# Regression tests for BEFORE INSERT triggers properly handling sqlite_sequence/AUTOINCREMENT
@skip-if mvcc "AUTOINCREMENT is not supported in MVCC mode"
@cross-check-integrity
test trigger-autoincrement-before-insert-delete-first-row {
    CREATE TABLE t_auto(id INTEGER PRIMARY KEY AUTOINCREMENT, v TEXT);
    CREATE TRIGGER t_auto_bi BEFORE INSERT ON t_auto BEGIN
        INSERT INTO t_auto(v) VALUES ('temp');
        DELETE FROM t_auto WHERE id = last_insert_rowid();
    END;
    INSERT INTO t_auto(v) VALUES ('real');
    SELECT id, v FROM t_auto ORDER BY id;
}
expect {
    2|real
}

@skip-if mvcc "AUTOINCREMENT is not supported in MVCC mode"
@cross-check-integrity
test trigger-autoincrement-before-insert-delete-multiple-rows {
    CREATE TABLE t_auto(id INTEGER PRIMARY KEY AUTOINCREMENT, v TEXT);
    CREATE TRIGGER t_auto_bi BEFORE INSERT ON t_auto BEGIN
        INSERT INTO t_auto(v) VALUES ('temp');
        DELETE FROM t_auto WHERE id = last_insert_rowid();
    END;
    INSERT INTO t_auto(v) VALUES ('real1');
    INSERT INTO t_auto(v) VALUES ('real2');
    SELECT id, v FROM t_auto ORDER BY id;
}
expect {
    2|real1
    4|real2
}

@skip-if mvcc "AUTOINCREMENT is not supported in MVCC mode"
@cross-check-integrity
test trigger-autoincrement-before-insert-delete-sequence {
    CREATE TABLE t_auto(id INTEGER PRIMARY KEY AUTOINCREMENT, v TEXT);
    CREATE TRIGGER t_auto_bi BEFORE INSERT ON t_auto BEGIN
        INSERT INTO t_auto(v) VALUES ('temp');
        DELETE FROM t_auto WHERE id = last_insert_rowid();
    END;
    INSERT INTO t_auto(v) VALUES ('real1');
    INSERT INTO t_auto(v) VALUES ('real2');
    SELECT name, seq FROM sqlite_sequence ORDER BY name;
}
expect {
    t_auto|4
}

test before-update-trigger-panic-on-update {
    CREATE TABLE t(id INTEGER PRIMARY KEY, v TEXT);
    CREATE TRIGGER tr BEFORE UPDATE ON t BEGIN SELECT 1; END;
    UPDATE t SET v='b' WHERE '';
    SELECT count(*) FROM t;
}
expect {
    0
}

test selectC-2-1 {
    CREATE TABLE t21a (a,b);
    INSERT INTO t21a VALUES(1,2);
    CREATE TABLE t21b (n);
    CREATE TRIGGER r21 AFTER INSERT ON t21b BEGIN
        SELECT a FROM t21a WHERE a>new.x UNION ALL
        SELECT b FROM t21a WHERE b>new.x ORDER BY 1 LIMIT 2;
    END;
    INSERT INTO t21b VALUES(6);
}
expect error {
    no such column: new.x
}
