# DELETE with transitive virtual column dependency (c depends on b which depends on a)
@cross-check-integrity
test delete-transitive-virtual-dep {
    CREATE TABLE t(a INTEGER, b AS (a * 2) VIRTUAL, c AS (b + 1) VIRTUAL);
    CREATE UNIQUE INDEX idx_c ON t(c);
    INSERT INTO t(a) VALUES(10);
    DELETE FROM t WHERE a = 10;
    SELECT count(*) FROM t;
}
expect {
    0
}

# FK CASCADE through transitive virtual columns
@cross-check-integrity
test fk-transitive-virtual-cascade {
    PRAGMA foreign_keys=ON;
    CREATE TABLE p(a INTEGER, b AS (a * 2) VIRTUAL, c AS (b + 10) VIRTUAL);
    CREATE UNIQUE INDEX idx_p_c ON p(c);
    CREATE TABLE child(x INTEGER REFERENCES p(c) ON DELETE CASCADE);
    INSERT INTO p(a) VALUES(5);
    INSERT INTO child(x) VALUES(20);
    DELETE FROM p WHERE a = 5;
    SELECT count(*) FROM child;
}
expect {
    0
}

test update-virtual-not-null {
    CREATE TABLE t(a, b AS (a) NOT NULL);
    INSERT INTO t VALUES (1);
    UPDATE t SET a = null;
}
expect error {
    NOT NULL constraint failed: t.b
}

test update-virtual-not-null-transitive {
    CREATE TABLE t(a, b AS (a), c as (b) NOT NULL);
    INSERT INTO t VALUES (1);
    UPDATE t SET a = null;
}
expect error {
    NOT NULL constraint failed: t.c
}

# Deferred NOT NULL: BEFORE UPDATE trigger fires before the NOT NULL check on
# a virtual column, so RAISE(IGNORE) silently skips the update and the row is
# left intact. If the NOT NULL check ran first, this would error out with
# "NOT NULL constraint failed: t.b".
@requires trigger "needs triggers"
test update-virtual-not-null-deferred-trigger-ignore {
    CREATE TABLE t(a, b AS (a) NOT NULL);
    INSERT INTO t VALUES (1);
    CREATE TRIGGER trg BEFORE UPDATE ON t WHEN NEW.a IS NULL BEGIN
        SELECT RAISE(IGNORE);
    END;
    UPDATE t SET a = null;
    SELECT a, b FROM t;
}
expect {
    1|1
}

# Same deferred-ordering check for a transitively-computed virtual column.
@requires trigger "needs triggers"
test update-virtual-not-null-transitive-deferred-trigger-ignore {
    CREATE TABLE t(a, b AS (a), c AS (b) NOT NULL);
    INSERT INTO t VALUES (1);
    CREATE TRIGGER trg BEFORE UPDATE ON t WHEN NEW.a IS NULL BEGIN
        SELECT RAISE(IGNORE);
    END;
    UPDATE t SET a = null;
    SELECT a, b, c FROM t;
}
expect {
    1|1|1
}

# Deferred NOT NULL: BEFORE UPDATE trigger raises a custom abort error, which
# must surface instead of the NOT NULL constraint error — proving the trigger
# ran before the deferred check.
@requires trigger "needs triggers"
test update-virtual-not-null-deferred-trigger-abort {
    CREATE TABLE t(a, b AS (a) NOT NULL);
    INSERT INTO t VALUES (1);
    CREATE TRIGGER trg BEFORE UPDATE ON t WHEN NEW.a IS NULL BEGIN
        SELECT RAISE(ABORT, 'trigger rejects null');
    END;
    UPDATE t SET a = null;
}
expect error {
    trigger rejects null
}

# Same deferred-ordering check for a transitively-computed virtual column.
@requires trigger "needs triggers"
test update-virtual-not-null-transitive-deferred-trigger-abort {
    CREATE TABLE t(a, b AS (a), c AS (b) NOT NULL);
    INSERT INTO t VALUES (1);
    CREATE TRIGGER trg BEFORE UPDATE ON t WHEN NEW.a IS NULL BEGIN
        SELECT RAISE(ABORT, 'trigger rejects null');
    END;
    UPDATE t SET a = null;
}
expect error {
    trigger rejects null
}

test gencol-virtual-join-inner-inner {
    CREATE TABLE t1(a, b AS (a*2));
    CREATE TABLE t2(x);
    CREATE TABLE t3(y);
    INSERT INTO t1(a) VALUES(1),(2),(3);
    INSERT INTO t2 VALUES(1),(2),(3);
    INSERT INTO t3 VALUES(1),(2),(3);
    SELECT t1.a FROM t1 JOIN t2 ON t1.a = t2.x JOIN t3 ON t1.a = t3.y;
}
expect {
    1
    2
    3
}

