test upsert-unique-virtual-column {
    create table t(a unique, b, c as (b) unique);
    insert into t values (1, 1), (2, 2);
    insert into t values (1, 2) on conflict(a) do update set b = excluded.b;
} expect error {
    UNIQUE constraint failed: t.c
}

test upsert-unique-virtual-column-ipk-autoindex {
    create table t(a integer primary key, b, c as (b) unique);
    insert into t values (1, 1), (2, 2);
    insert into t values (1, 2) on conflict(a) do update set b = excluded.b;
} expect error {
    UNIQUE constraint failed: t.c
}

test upsert-unique-virtual-column-ipk {
    create table t(a integer primary key, b, c as (b));
    create unique index idx on t(c);
    insert into t values (1, 1), (2, 2);
    insert into t values (1, 2) on conflict(a) do update set b = excluded.b;
} expect error {
    UNIQUE constraint failed: t.c
}

test update-deferred-fk-on-child-virtual-column {
  PRAGMA foreign_keys=on;
  CREATE TABLE p(x PRIMARY KEY);
  CREATE TABLE c(a, b AS (a), FOREIGN KEY(b) REFERENCES p DEFERRABLE INITIALLY DEFERRED);
  INSERT INTO p VALUES (1);
  INSERT INTO c VALUES (1);
  UPDATE c SET a=2;
} expect error {
    (FOREIGN KEY|deferred foreign key) constraint failed
}

