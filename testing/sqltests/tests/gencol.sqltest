@database :memory:

# =============================================================================
# 1. Basics & Syntax Variants
# =============================================================================

test gencol_virtual_basic_1 {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    SELECT a, b FROM t1;
}
expect {
    5|10
}

test gencol_virtual_basic_2 {
    CREATE TABLE t1(a INTEGER, b AS (a*2) VIRTUAL);
    INSERT INTO t1(a) VALUES(7);
    SELECT a, b FROM t1;
}
expect {
    7|14
}

test gencol_virtual_select_star {
    CREATE TABLE t1(x, y AS (x+1), z);
    INSERT INTO t1(x, z) VALUES(10, 30);
    SELECT * FROM t1;
}
expect {
    10|11|30
}

test gencol_virtual_expression_concat {
    CREATE TABLE t1(first TEXT, last TEXT, full AS (first || ' ' || last));
    INSERT INTO t1(first, last) VALUES('John', 'Doe');
    SELECT full FROM t1;
}
expect {
    John Doe
}

test gencol_generated_always_virtual {
    CREATE TABLE t1(a INTEGER, b GENERATED ALWAYS AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    SELECT b FROM t1;
}
expect {
    10
}

# Multiple generated columns
test gencol_multiple_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a*2), c AS (a*3), d AS (a*4));
    INSERT INTO t1(a) VALUES(5);
    SELECT b, c, d FROM t1;
}
expect {
    10|15|20
}

# Test that INTEGER AS columns are correctly marked as VIRTUAL (hidden=2).
test gencol_pragma_table_xinfo_integer_as_virtual {
    CREATE TABLE t1(a REAL, b INTEGER AS (a), c REAL AS (b), d INTEGER AS (c + 1));
    PRAGMA table_xinfo(t1);
}
expect {
    0|a|REAL|0||0|0
    1|b|INTEGER|0||0|2
    2|c|REAL|0||0|2
    3|d|INTEGER|0||0|2
}

# =============================================================================
# 2. Expression Types
# =============================================================================

# --- Arithmetic operators ---

test gencol_arithmetic_add {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a+b));
    INSERT INTO t1(a, b) VALUES(3, 7);
    SELECT c FROM t1;
}
expect {
    10
}

test gencol_arithmetic_subtract {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a-b));
    INSERT INTO t1(a, b) VALUES(10, 3);
    SELECT c FROM t1;
}
expect {
    7
}

test gencol_arithmetic_multiply {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a*b));
    INSERT INTO t1(a, b) VALUES(4, 5);
    SELECT c FROM t1;
}
expect {
    20
}

test gencol_arithmetic_divide {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a/b));
    INSERT INTO t1(a, b) VALUES(20, 4);
    SELECT c FROM t1;
}
expect {
    5
}

test gencol_arithmetic_modulo {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a%b));
    INSERT INTO t1(a, b) VALUES(17, 5);
    SELECT c FROM t1;
}
expect {
    2
}

# --- Comparison operators ---

test gencol_comparison_equal {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a=b));
    INSERT INTO t1(a, b) VALUES(5, 5), (5, 6);
    SELECT c FROM t1;
}
expect {
    1
    0
}

test gencol_comparison_greater {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a>b));
    INSERT INTO t1(a, b) VALUES(10, 5), (3, 7);
    SELECT c FROM t1;
}
expect {
    1
    0
}

# TEXT column uses text comparison: '10' > '5' is false (lexicographic)
@skip "TODO needs virtual column affinity handling"
test gencol_comparison_affinity_text_integer {
    CREATE TABLE t1(a TEXT, b INTEGER AS (a > 5));
    INSERT INTO t1(a) VALUES('10'), ('3'), ('7');
    SELECT a, b FROM t1;
}
expect {
    10|0
    3|0
    7|1
}

@skip "TODO needs virtual column affinity handling"
test gencol_comparison_affinity_equals {
    CREATE TABLE t1(a TEXT, b INTEGER AS (a = 10));
    INSERT INTO t1(a) VALUES('10'), ('5');
    SELECT a, b FROM t1;
}
expect {
    10|1
    5|0
}

@skip "TODO needs virtual column affinity handling"
test gencol_comparison_affinity_null {
    CREATE TABLE t1(a TEXT, b INTEGER AS (a > 5));
    INSERT INTO t1(a) VALUES(NULL), ('10');
    SELECT a, b FROM t1;
}
expect {
    |
    10|0
}

@skip "TODO needs virtual column affinity handling"
test gencol_comparison_affinity_negative {
    CREATE TABLE t1(a TEXT, b INTEGER AS (a > -5));
    INSERT INTO t1(a) VALUES('-3'), ('-7'), ('0');
    SELECT a, b FROM t1;
}
expect {
    -3|0
    -7|1
    0|1
}

@skip "TODO needs virtual column affinity handling"
test gencol_comparison_affinity_real {
    CREATE TABLE t1(a TEXT, b INTEGER AS (a > 5.5));
    INSERT INTO t1(a) VALUES('6'), ('5'), ('5.5');
    SELECT a, b FROM t1;
}
expect {
    6|1
    5|0
    5.5|0
}

# --- Unary operators ---

test gencol_unary_negative {
    CREATE TABLE t1(a INTEGER, b AS (-a));
    INSERT INTO t1(a) VALUES(5);
    SELECT b FROM t1;
}
expect {
    -5
}

test gencol_unary_positive {
    CREATE TABLE t1(a INTEGER, b AS (+a));
    INSERT INTO t1(a) VALUES(5);
    SELECT b FROM t1;
}
expect {
    5
}

test gencol_unary_not {
    CREATE TABLE t1(a INTEGER, b AS (NOT a));
    INSERT INTO t1(a) VALUES(0), (1);
    SELECT a, b FROM t1;
}
expect {
    0|1
    1|0
}

# --- Bitwise operators ---

test gencol_bitwise_and {
    CREATE TABLE t1(a INT, b INT, c AS (a & b));
    INSERT INTO t1(a, b) VALUES(15, 9);
    SELECT c FROM t1;
}
expect {
    9
}

test gencol_bitwise_or {
    CREATE TABLE t1(a INT, b INT, c AS (a | b));
    INSERT INTO t1(a, b) VALUES(15, 9);
    SELECT c FROM t1;
}
expect {
    15
}

test gencol_shift_left {
    CREATE TABLE t1(a INT, b INT, c AS (a << b));
    INSERT INTO t1(a, b) VALUES(1, 4);
    SELECT c FROM t1;
}
expect {
    16
}

test gencol_shift_right {
    CREATE TABLE t1(a INT, b INT, c AS (a >> b));
    INSERT INTO t1(a, b) VALUES(16, 2);
    SELECT c FROM t1;
}
expect {
    4
}

test gencol_bitwise_not {
    CREATE TABLE t1(a INT, b AS (~a));
    INSERT INTO t1(a) VALUES(0);
    SELECT b FROM t1;
}
expect {
    -1
}

# --- CASE expressions ---

test gencol_case_expression {
    CREATE TABLE t1(a INTEGER, b AS (CASE WHEN a > 0 THEN 'positive' WHEN a < 0 THEN 'negative' ELSE 'zero' END));
    INSERT INTO t1(a) VALUES(5), (-3), (0);
    SELECT a, b FROM t1;
}
expect {
    5|positive
    -3|negative
    0|zero
}

test gencol_case_base_column {
    CREATE TABLE t1(a INTEGER, b AS (CASE a WHEN 1 THEN 'one' WHEN 2 THEN 'two' ELSE 'other' END));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    SELECT a, b FROM t1;
}
expect {
    1|one
    2|two
    3|other
}

test gencol_case_multi_column {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (CASE WHEN a > b THEN a WHEN b > a THEN b ELSE 0 END));
    INSERT INTO t1(a, b) VALUES(5, 3), (2, 8), (4, 4);
    SELECT c FROM t1;
}
expect {
    5
    8
    0
}

test gencol_case_nested {
    CREATE TABLE t1(a INTEGER, b AS (CASE WHEN a > 0 THEN CASE WHEN a > 10 THEN 'large' ELSE 'small' END ELSE 'negative' END));
    INSERT INTO t1(a) VALUES(20), (5), (-3);
    SELECT a, b FROM t1;
}
expect {
    20|large
    5|small
    -3|negative
}

test gencol_case_no_else {
    CREATE TABLE t1(a INTEGER, b AS (CASE WHEN a = 1 THEN 'one' WHEN a = 2 THEN 'two' END));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    SELECT a, b FROM t1;
}
expect {
    1|one
    2|two
    3|
}

test gencol_case_with_not {
    CREATE TABLE t1(a INTEGER, b AS (CASE WHEN NOT (a > 0) THEN 'non-positive' ELSE 'positive' END));
    INSERT INTO t1(a) VALUES(5), (-3), (0);
    SELECT a, b FROM t1;
}
expect {
    5|positive
    -3|non-positive
    0|non-positive
}

# --- CAST, COLLATE, parenthesized ---

test gencol_validate_cast {
    CREATE TABLE t1(a INTEGER, b AS (CAST(a AS TEXT)));
    INSERT INTO t1(a) VALUES(42);
    SELECT typeof(b), b FROM t1;
}
expect {
    text|42
}

test gencol_validate_parenthesized {
    CREATE TABLE t1(a INTEGER, b AS ((a + 1)));
    INSERT INTO t1(a) VALUES(5);
    SELECT b FROM t1;
}
expect {
    6
}

test gencol_parentheses {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS ((a+b)*2));
    INSERT INTO t1(a, b) VALUES(3, 7);
    SELECT c FROM t1;
}
expect {
    20
}

test gencol_validate_collate {
    CREATE TABLE t1(a TEXT, b AS (a COLLATE NOCASE));
    INSERT INTO t1(a) VALUES('Hello');
    SELECT b FROM t1;
}
expect {
    Hello
}

# --- BETWEEN, IN, LIKE ---

test gencol_between {
    CREATE TABLE t1(a INTEGER, b AS (a BETWEEN 5 AND 10));
    INSERT INTO t1(a) VALUES(3), (7), (12);
    SELECT a, b FROM t1;
}
expect {
    3|0
    7|1
    12|0
}

test gencol_between_update {
    CREATE TABLE t1(a INTEGER, b AS (a BETWEEN 5 AND 10));
    INSERT INTO t1(a) VALUES(3);
    UPDATE t1 SET a = 7;
    SELECT a, b FROM t1;
}
expect {
    7|1
}

test gencol_in_list {
    CREATE TABLE t1(a INTEGER, b AS (a IN (1, 3, 5, 7, 9)));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    SELECT a, b FROM t1;
}
expect {
    1|1
    2|0
    3|1
}

test gencol_in_list_update {
    CREATE TABLE t1(a INTEGER, b AS (a IN (1, 3, 5, 7, 9)));
    INSERT INTO t1(a) VALUES(1);
    UPDATE t1 SET a = 2;
    SELECT a, b FROM t1;
}
expect {
    2|0
}

test gencol_like {
    CREATE TABLE t1(a TEXT, b AS (a LIKE '%ell%'));
    INSERT INTO t1(a) VALUES('hello'), ('world'), ('shell');
    SELECT a, b FROM t1;
}
expect {
    hello|1
    world|0
    shell|1
}

test gencol_like_update {
    CREATE TABLE t1(a TEXT, b AS (a LIKE '%ell%'));
    INSERT INTO t1(a) VALUES('hello');
    UPDATE t1 SET a = 'world';
    SELECT a, b FROM t1;
}
expect {
    world|0
}

test gencol_validate_like_escape {
    CREATE TABLE t1(a TEXT, b AS (a LIKE '%!%%' ESCAPE '!'));
    INSERT INTO t1(a) VALUES('100%'), ('hello'), ('50% off');
    SELECT a, b FROM t1;
}
expect {
    100%|1
    hello|0
    50% off|1
}

# --- ISNULL / NOTNULL keywords ---

test gencol_validate_isnull {
    CREATE TABLE t1(a INTEGER, b AS (a ISNULL));
    INSERT INTO t1(a) VALUES(NULL), (5);
    SELECT a, b FROM t1;
}
expect {
    |1
    5|0
}

test gencol_validate_notnull {
    CREATE TABLE t1(a INTEGER, b AS (a NOTNULL));
    INSERT INTO t1(a) VALUES(NULL), (5);
    SELECT a, b FROM t1;
}
expect {
    |0
    5|1
}

# =============================================================================
# 3. Functions in Expressions
# =============================================================================

test gencol_func_abs {
    CREATE TABLE t1(a INTEGER, b AS (ABS(a)));
    INSERT INTO t1(a) VALUES(-5);
    SELECT b FROM t1;
}
expect {
    5
}

test gencol_func_length {
    CREATE TABLE t1(a TEXT, b AS (LENGTH(a)));
    INSERT INTO t1(a) VALUES('hello');
    SELECT b FROM t1;
}
expect {
    5
}

test gencol_func_upper {
    CREATE TABLE t1(a TEXT, b AS (UPPER(a)));
    INSERT INTO t1(a) VALUES('hello');
    SELECT b FROM t1;
}
expect {
    HELLO
}

test gencol_func_lower {
    CREATE TABLE t1(a TEXT, b AS (LOWER(a)));
    INSERT INTO t1(a) VALUES('HELLO');
    SELECT b FROM t1;
}
expect {
    hello
}

test gencol_func_substr {
    CREATE TABLE t1(a TEXT, b AS (SUBSTR(a, 1, 3)));
    INSERT INTO t1(a) VALUES('hello');
    SELECT b FROM t1;
}
expect {
    hel
}

test gencol_func_ifnull {
    CREATE TABLE t1(a INTEGER, b AS (IFNULL(a, 0)));
    INSERT INTO t1(a) VALUES(NULL);
    UPDATE t1 SET a = 5;
    SELECT b FROM t1;
}
expect {
    5
}

test gencol_func_nested_abs {
    CREATE TABLE t1(a INTEGER, b AS (ABS(ABS(a))));
    INSERT INTO t1(a) VALUES(-5);
    SELECT b FROM t1;
}
expect {
    5
}

test gencol_func_nested_upper_substr {
    CREATE TABLE t1(a TEXT, b AS (UPPER(SUBSTR(a, 1, 3))));
    INSERT INTO t1(a) VALUES('hello');
    SELECT b FROM t1;
}
expect {
    HEL
}

test gencol_func_coalesce_multi_col {
    CREATE TABLE t1(a INTEGER, b INTEGER, c INTEGER, d AS (COALESCE(a, b, c)));
    INSERT INTO t1(a, b, c) VALUES(NULL, NULL, 3);
    UPDATE t1 SET b = 7;
    SELECT d FROM t1;
}
expect {
    7
}

test gencol_func_ifnull_two_cols {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (IFNULL(a, b)));
    INSERT INTO t1(a, b) VALUES(NULL, 42);
    UPDATE t1 SET a = 10;
    SELECT c FROM t1;
}
expect {
    10
}

test gencol_func_abs_arithmetic {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (ABS(a - b)));
    INSERT INTO t1(a, b) VALUES(3, 10);
    SELECT c FROM t1;
}
expect {
    7
}

test gencol_func_multi_abs_arithmetic {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (ABS(a) + ABS(b)));
    INSERT INTO t1(a, b) VALUES(-3, -7);
    SELECT c FROM t1;
}
expect {
    10
}

test gencol_func_dependency_chain {
    CREATE TABLE t1(a INTEGER, b AS (ABS(a)), c AS (b * 2));
    INSERT INTO t1(a) VALUES(-5);
    SELECT a, b, c FROM t1;
}
expect {
    -5|5|10
}

test gencol_func_min_cols {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (MIN(a, b)));
    INSERT INTO t1(a, b) VALUES(3, 7), (10, 2);
    SELECT c FROM t1;
}
expect {
    3
    2
}

test gencol_func_max_cols {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (MAX(a, b)));
    INSERT INTO t1(a, b) VALUES(3, 7), (10, 2);
    SELECT c FROM t1;
}
expect {
    7
    10
}

test gencol_glob_pattern_column {
    CREATE TABLE t1(a TEXT, b AS (a GLOB '[0-9]*'));
    INSERT INTO t1(a) VALUES('123abc'), ('abc123'), ('456');
    SELECT a, b FROM t1;
}
expect {
    123abc|1
    abc123|0
    456|1
}

# =============================================================================
# 4. Column Dependency Chains
# =============================================================================

test gencol_dependency_chain_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a*2), c AS (b*2));
    INSERT INTO t1(a) VALUES(3);
    SELECT a, b, c FROM t1;
}
expect {
    3|6|12
}

test gencol_dependency_out_of_order_virtual {
    CREATE TABLE t1(a INTEGER, c AS (b+1), b AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    SELECT a, b, c FROM t1;
}
expect {
    5|10|11
}

test gencol_dependency_reverse_order_virtual {
    CREATE TABLE t1(a INTEGER, d AS (c+1), c AS (b+1), b AS (a*2));
    INSERT INTO t1(a) VALUES(3);
    SELECT a, b, c, d FROM t1;
}
expect {
    3|6|7|8
}

test gencol_dependency_diamond_virtual {
    CREATE TABLE t1(a INTEGER, d AS (b + c), b AS (a*2), c AS (a*3));
    INSERT INTO t1(a) VALUES(5);
    SELECT a, b, c, d FROM t1;
}
expect {
    5|10|15|25
}

# Forward references are allowed in SQLite generated columns
test gencol_forward_reference {
    CREATE TABLE t1(a AS (b*2), b INTEGER);
    INSERT INTO t1(b) VALUES(5);
    SELECT a, b FROM t1;
}
expect {
    10|5
}

# =============================================================================
# 5. Type Affinity
# =============================================================================

test gencol_affinity_integer {
    CREATE TABLE t1(a TEXT, b INTEGER AS (a*2));
    INSERT INTO t1(a) VALUES('5');
    SELECT typeof(b), b FROM t1;
}
expect {
    integer|10
}

test gencol_affinity_text {
    CREATE TABLE t1(a INTEGER, b TEXT AS (a || 'x'));
    INSERT INTO t1(a) VALUES(42);
    SELECT typeof(b), b FROM t1;
}
expect {
    text|42x
}

test gencol_affinity_real {
    CREATE TABLE t1(a INTEGER, b REAL AS (a/2.0));
    INSERT INTO t1(a) VALUES(5);
    SELECT typeof(b), b FROM t1;
}
expect {
    real|2.5
}

test gencol_affinity_float_to_int_exact {
    CREATE TABLE t1(a REAL, b INTEGER AS (a));
    INSERT INTO t1(a) VALUES (5.0);
    SELECT typeof(b), b FROM t1;
}
expect {
    integer|5
}

test gencol_affinity_float_fractional {
    CREATE TABLE t1(a REAL);
    INSERT INTO t1(a) VALUES (5.5);
    SELECT typeof(a), a FROM t1;
}
expect {
    real|5.5
}

test gencol_affinity_large_int_exact {
    CREATE TABLE t1(a REAL, b INTEGER AS (a));
    INSERT INTO t1(a) VALUES (1000000.0);
    SELECT typeof(b), b FROM t1;
}
expect {
    integer|1000000
}

test gencol_affinity_numeric_float_to_int {
    CREATE TABLE t1(a REAL, b NUMERIC AS (a));
    INSERT INTO t1(a) VALUES (42.0);
    SELECT typeof(b), b FROM t1;
}
expect {
    integer|42
}

test gencol_affinity_numeric_fractional {
    CREATE TABLE t1(a REAL, b NUMERIC AS (a));
    INSERT INTO t1(a) VALUES (42.5);
    SELECT typeof(b), b FROM t1;
}
expect {
    real|42.5
}

test gencol_float_literal_in_expr {
    CREATE TABLE t1(a INTEGER, b REAL AS (a + 0.5));
    INSERT INTO t1(a) VALUES (5);
    SELECT typeof(b), b FROM t1;
}
expect {
    real|5.5
}

test gencol_division_exact_int {
    CREATE TABLE t1(a INTEGER, b INTEGER, c INTEGER AS (a / b));
    INSERT INTO t1(a, b) VALUES (10, 2);
    SELECT typeof(c), c FROM t1;
}
expect {
    integer|5
}

test gencol_division_truncated {
    CREATE TABLE t1(a INTEGER, b INTEGER, c INTEGER AS (a / b));
    INSERT INTO t1(a, b) VALUES (10, 3);
    SELECT typeof(c), c FROM t1;
}
expect {
    integer|3
}

# NUMERIC affinity: text "3.0" -> float 3.0 -> integer 3
test gencol_numeric_affinity {
    CREATE TABLE t1(a TEXT, b NUMERIC GENERATED ALWAYS AS (a) VIRTUAL);
    INSERT INTO t1(a) VALUES('3.0');
    SELECT typeof(b), b FROM t1;
}
expect {
    integer|3
}

# REAL->INTEGER->REAL->INTEGER affinity chain
test gencol_virtual_affinity_chain {
    CREATE TABLE t1 (
        a REAL,
        b INTEGER AS (a),
        c REAL AS (b),
        d INTEGER AS (- (c - (141 - c)))
    );
    INSERT INTO t1 (a) VALUES (10.0);
    SELECT typeof(a), typeof(b), typeof(c), typeof(d) FROM t1;
    SELECT a, b, c, d FROM t1;
}
expect {
    real|integer|real|integer
    10.0|10|10.0|121
}
# JS Number omits .0 for whole numbers
expect @js {
    real|integer|real|integer
    10|10|10|121
}

@skip-if sqlite "bug/quirk in SQLite: the sorter strips the internal MEM_IntReal optimization, so the value is formatted as an int"
test gencol_intreal_typeof {
    CREATE TABLE t1 (b REAL, c REAL AS (b));
    INSERT INTO t1 VALUES (20.0);
    SELECT typeof(c), c FROM t1 ORDER BY c;
}
expect {
    real|20.0
}
expect @js {
    real|20
}

# Generated columns use their own collation (BINARY), not the source column's
test gencol_collation_not_inherited {
    CREATE TABLE t1(name TEXT COLLATE NOCASE, gen TEXT GENERATED ALWAYS AS (name));
    INSERT INTO t1(name) VALUES('b'),('a'),('B'),('A');
    SELECT gen FROM t1 ORDER BY gen;
}
expect {
    A
    B
    a
    b
}

test gencol_type_mismatch_text_in_integer {
    CREATE TABLE t1(a TEXT, b INTEGER AS (a));
    INSERT INTO t1(a) VALUES('hello');
    SELECT typeof(b), b FROM t1;
}
expect {
    text|hello
}

test gencol_type_mismatch_int_in_text {
    CREATE TABLE t1(a INTEGER, b TEXT AS (a));
    INSERT INTO t1(a) VALUES(42);
    SELECT typeof(b), b FROM t1;
}
expect {
    text|42
}

test gencol_type_mismatch_real_in_integer {
    CREATE TABLE t1(a REAL, b INTEGER AS (a));
    INSERT INTO t1(a) VALUES(3.7);
    SELECT typeof(b), b FROM t1;
}
expect {
    real|3.7
}

test gencol_type_mismatch_blob_in_text {
    CREATE TABLE t1(a BLOB, b TEXT AS (a));
    INSERT INTO t1(a) VALUES(x'DEADBEEF');
    SELECT typeof(b), quote(b) FROM t1;
}
expect {
    blob|X'DEADBEEF'
}

# =============================================================================
# 6. Column Positions
# =============================================================================

test gencol_first_position {
    CREATE TABLE t1(a AS (b+c), b INTEGER, c INTEGER);
    INSERT INTO t1(b, c) VALUES(3, 5);
    SELECT a, b, c FROM t1;
}
expect {
    8|3|5
}

test gencol_middle_position {
    CREATE TABLE t1(a INTEGER, b AS (a*2), c INTEGER);
    INSERT INTO t1(a, c) VALUES(5, 100);
    SELECT a, b, c FROM t1;
}
expect {
    5|10|100
}

test gencol_last_position {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a+b));
    INSERT INTO t1(a, b) VALUES(3, 7);
    SELECT a, b, c FROM t1;
}
expect {
    3|7|10
}

# =============================================================================
# 7. NULL Handling
# =============================================================================

test gencol_null_input {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(NULL);
    SELECT a, b FROM t1;
}
expect {
    |
}

test gencol_null_in_expression {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a+b));
    INSERT INTO t1(a, b) VALUES(5, NULL);
    SELECT c FROM t1;
}
expect {

}

test gencol_coalesce_null {
    CREATE TABLE t1(a INTEGER, b AS (COALESCE(a, 0) * 2));
    INSERT INTO t1(a) VALUES(NULL);
    UPDATE t1 SET a = 5;
    SELECT b FROM t1;
}
expect {
    10
}

# SQL three-valued logic: NULL AND TRUE = NULL, NULL AND FALSE = FALSE
test gencol_null_and_semantics {
    CREATE TABLE t1(a INT, b INT, c AS (a AND b));
    INSERT INTO t1(a, b) VALUES(NULL, 1), (NULL, 0), (1, NULL), (0, NULL);
    SELECT a, b, c FROM t1;
}
expect {
    |1|
    |0|0
    1||
    0||0
}

# NULL OR TRUE = TRUE, NULL OR FALSE = NULL
test gencol_null_or_semantics {
    CREATE TABLE t1(a INT, b INT, c AS (a OR b));
    INSERT INTO t1(a, b) VALUES(NULL, 0), (NULL, 1), (0, NULL), (1, NULL);
    SELECT a, b, c FROM t1;
}
expect {
    |0|
    |1|1
    0||
    1||1
}

# IN-list NULL handling with generated columns
test gencol_in_list_null_handling {
    CREATE TABLE t1(a INTEGER, b AS (a) VIRTUAL);
    INSERT INTO t1(a) VALUES(1), (2), (NULL);
    SELECT a, b IN (1, NULL) FROM t1 ORDER BY a;
}
expect {
    |
    1|1
    2|
}

# =============================================================================
# 8. DML (INSERT, UPDATE, DELETE, RETURNING)
# =============================================================================

test gencol_update_virtual_unchanged {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    UPDATE t1 SET a = 10;
    SELECT a, b FROM t1;
}
expect {
    10|20
}

# INSERT DEFAULT VALUES with virtual generated column
test gencol_insert_default_values_virtual {
    CREATE TABLE t1(a INT DEFAULT 10, b INT GENERATED ALWAYS AS (a + 5) VIRTUAL);
    INSERT INTO t1 DEFAULT VALUES;
    SELECT * FROM t1;
}
expect {
    10|15
}

# --- Division by zero handling ---

test gencol_division_by_zero_null {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a / b));
    INSERT INTO t1(a, b) VALUES (10, 0);
    UPDATE t1 SET a = 20;
    SELECT a, b, c FROM t1;
}
expect {
    20|0|
}

test gencol_modulo_by_zero {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a % b));
    INSERT INTO t1(a, b) VALUES (10, 0);
    UPDATE t1 SET a = 20;
    SELECT a, b, c FROM t1;
}
expect {
    20|0|
}

test gencol_division_by_zero_coalesce {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (COALESCE(a / NULLIF(b, 0), 0)));
    INSERT INTO t1(a, b) VALUES (10, 0);
    SELECT a, b, c FROM t1;
}
expect {
    10|0|0
}

test gencol_division_by_zero_case {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (CASE WHEN b = 0 THEN 0 ELSE a / b END));
    INSERT INTO t1(a, b) VALUES (10, 0), (10, 2);
    SELECT a, b, c FROM t1 ORDER BY b;
}
expect {
    10|0|0
    10|2|5
}

# --- RETURNING ---

test gencol_returning_insert_star_middle {
    CREATE TABLE t1(a INT, v AS (a*2) VIRTUAL, b INT);
    INSERT INTO t1(a, b) VALUES(1, 100) RETURNING *;
}
expect {
    1|2|100
}

test gencol_returning_insert_specific_cols {
    CREATE TABLE t1(a INT, v AS (a*2) VIRTUAL, b INT);
    INSERT INTO t1(a, b) VALUES(5, 50) RETURNING a, b, v;
}
expect {
    5|50|10
}

test gencol_returning_update_star {
    CREATE TABLE t1(a INT, v AS (a*2) VIRTUAL, b INT);
    INSERT INTO t1(a, b) VALUES(1, 100);
    UPDATE t1 SET a = 10 RETURNING *;
}
expect {
    10|20|100
}

test gencol_returning_virtual_first {
    CREATE TABLE t1(v AS (b*3) VIRTUAL, a INT, b INT);
    INSERT INTO t1(a, b) VALUES(1, 2) RETURNING *;
}
expect {
    6|1|2
}

test gencol_returning_multiple_virtual {
    CREATE TABLE t1(a INT, v1 AS (a*2) VIRTUAL, b INT, v2 AS (b*3) VIRTUAL, c INT);
    INSERT INTO t1(a, b, c) VALUES(1, 2, 3) RETURNING *;
}
expect {
    1|2|2|6|3
}

# --- Virtual column chain updates ---

test gencol_virtual_chain_update {
    CREATE TABLE t1 (
        a REAL,
        b INTEGER AS (a),
        c REAL AS (b),
        d INTEGER AS (- (c - (141 - c)))
    );
    INSERT INTO t1 (a) VALUES (1.5);
    UPDATE t1 SET a = 2.7;
    SELECT a, b, c, d FROM t1;
}
expect {
    2.7|2.7|2.7|135.6
}

test gencol_virtual_simple_update {
    CREATE TABLE t1 (
        a REAL,
        b REAL AS (a * 2)
    );
    INSERT INTO t1 (a) VALUES (5.0);
    SELECT a, b FROM t1;
}
expect {
    5.0|10.0
}
# JS Number omits .0 for whole numbers
expect @js {
    5|10
}

test gencol_virtual_simple_update_2 {
    CREATE TABLE t1 (
        a REAL,
        b REAL AS (a * 2)
    );
    INSERT INTO t1 (a) VALUES (5.0);
    UPDATE t1 SET a = 10.0;
    SELECT a, b FROM t1;
}
expect {
    10.0|20.0
}
# JS Number omits .0 for whole numbers
expect @js {
    10|20
}

test gencol_virtual_three_deep {
    CREATE TABLE t1 (
        base REAL,
        level1 REAL AS (base + 10),
        level2 REAL AS (level1 + 100),
        level3 REAL AS (level2 + 1000)
    );
    INSERT INTO t1 (base) VALUES (1);
    SELECT base, level1, level2, level3 FROM t1;
}
expect {
    1.0|11.0|111.0|1111.0
}
# JS Number omits .0 for whole numbers
expect @js {
    1|11|111|1111
}

test gencol_virtual_three_deep_update {
    CREATE TABLE t1 (
        base REAL,
        level1 REAL AS (base + 10),
        level2 REAL AS (level1 + 100),
        level3 REAL AS (level2 + 1000)
    );
    INSERT INTO t1 (base) VALUES (1);
    UPDATE t1 SET base = 2;
    SELECT base, level1, level2, level3 FROM t1;
}
expect {
    2.0|12.0|112.0|1112.0
}
expect @js {
    2|12|112|1112
}

# UPDATE with virtual column as FIRST column
test gencol_update_virtual_first_col {
    CREATE TABLE t1(v AS (b*3) VIRTUAL, a INT, b INT);
    INSERT INTO t1(a, b) VALUES(1, 2);
    UPDATE t1 SET a = 10;
    SELECT * FROM t1;
}
expect {
    6|10|2
}

# UPDATE with VIRTUAL column referencing id (verify still works)
test gencol_rowid_alias_update_virtual {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, other INTEGER, b AS (id + other));
    INSERT INTO t1(id, other) VALUES (5, 10);
    UPDATE t1 SET other = 20;
    SELECT id, other, b FROM t1;
}
expect {
    5|20|25
}

test gencol_delete_where_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) VALUES(1), (2), (3), (4), (5);
    DELETE FROM t1 WHERE b > 6;
    SELECT a, b FROM t1;
}
expect {
    1|2
    2|4
    3|6
}

test gencol_delete_multiple_verify_remaining {
    CREATE TABLE t1(a INTEGER, b TEXT, c AS (a || '-' || b));
    INSERT INTO t1(a, b) VALUES(1, 'x'), (2, 'y'), (3, 'z'), (4, 'w');
    DELETE FROM t1 WHERE a IN (2, 4);
    SELECT a, b, c FROM t1;
}
expect {
    1|x|1-x
    3|z|3-z
}

test gencol_replace_into {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b TEXT, c AS (b || '!'));
    INSERT INTO t1(a, b) VALUES(1, 'hello');
    REPLACE INTO t1(a, b) VALUES(1, 'world');
    SELECT a, b, c FROM t1;
}
expect {
    1|world|world!
}

test gencol_insert_or_replace {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b * 10));
    INSERT INTO t1(a, b) VALUES(1, 5);
    INSERT OR REPLACE INTO t1(a, b) VALUES(1, 9);
    SELECT a, b, c FROM t1;
}
expect {
    1|9|90
}

test gencol_insert_or_replace_not_null_no_default {
    CREATE TABLE t(a, b AS (a) NOT NULL);
    INSERT INTO t VALUES (1);
    UPDATE OR REPLACE t SET a = null;
}
expect error {
    NOT NULL constraint failed: t.b
}

test gencol_insert_or_ignore {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b + 100));
    INSERT INTO t1(a, b) VALUES(1, 5);
    INSERT OR IGNORE INTO t1(a, b) VALUES(1, 9);
    SELECT a, b, c FROM t1;
}
expect {
    1|5|105
}

@skip "TODO: INSERT OR REPLACE with virtual column index triggers SELF_TABLE parse error"
@skip-if mvcc "Expression indexes are not supported with MVCC"
test gencol_insert_or_replace_with_index {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b * 2));
    CREATE INDEX idx1 ON t1(c);
    INSERT INTO t1(a, b) VALUES(1, 5);
    INSERT OR REPLACE INTO t1(a, b) VALUES(1, 20);
    SELECT a, b, c FROM t1;
    PRAGMA integrity_check;
}
expect {
    1|20|40
    ok
}

test gencol_delete_basic {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    DELETE FROM t1 WHERE a = 2;
    SELECT a, b FROM t1 ORDER BY a;
}
expect {
    1|2
    3|6
}

test gencol_delete_all {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    DELETE FROM t1;
    SELECT COUNT(*) FROM t1;
}
expect {
    0
}

# DELETE with virtual column in middle of table
test gencol_delete_virtual_middle {
    CREATE TABLE t1(a INTEGER, v AS (a * 2), c INTEGER);
    INSERT INTO t1(a, c) VALUES(1, 10), (2, 20), (3, 30);
    DELETE FROM t1 WHERE v = 4;
    SELECT a, v, c FROM t1 ORDER BY a;
}
expect {
    1|2|10
    3|6|30
}

# DELETE with chained virtual columns
test gencol_delete_chained_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c AS (b + 1));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    DELETE FROM t1 WHERE c > 5;
    SELECT a, b, c FROM t1 ORDER BY a;
}
expect {
    1|2|3
    2|4|5
}

test gencol_insert_or_replace_multiple {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b * 3));
    INSERT INTO t1(a, b) VALUES(1, 10), (2, 20), (3, 30);
    INSERT OR REPLACE INTO t1(a, b) VALUES(2, 200), (4, 40);
    SELECT a, b, c FROM t1 ORDER BY a;
}
expect {
    1|10|30
    2|200|600
    3|30|90
    4|40|120
}

test gencol_replace_virtual_first_col {
    CREATE TABLE t1(v AS (b * 2) VIRTUAL, a INTEGER PRIMARY KEY, b INTEGER);
    INSERT INTO t1(a, b) VALUES(1, 5);
    REPLACE INTO t1(a, b) VALUES(1, 15);
    SELECT * FROM t1;
}
expect {
    30|1|15
}

test gencol_insert_or_ignore_notnull_violation {
    CREATE TABLE t1(a INTEGER NOT NULL, b AS (a * 2));
    INSERT OR IGNORE INTO t1(a) VALUES(5);
    INSERT OR IGNORE INTO t1(a) VALUES(NULL);
    SELECT a, b FROM t1;
}
expect {
    5|10
}

test gencol_insert_select_basic {
    CREATE TABLE src(x INTEGER);
    INSERT INTO src VALUES(1), (2), (3);
    CREATE TABLE dst(a INTEGER, b AS (a * 2));
    INSERT INTO dst(a) SELECT x FROM src;
    SELECT a, b FROM dst ORDER BY a;
}
expect {
    1|2
    2|4
    3|6
}

test gencol_insert_select_with_transform {
    CREATE TABLE src(x INTEGER, y INTEGER);
    INSERT INTO src VALUES(1, 10), (2, 20);
    CREATE TABLE dst(a INTEGER, b INTEGER, c AS (a + b));
    INSERT INTO dst(a, b) SELECT x, y FROM src;
    SELECT a, b, c FROM dst ORDER BY a;
}
expect {
    1|10|11
    2|20|22
}

test gencol_insert_select_from_gencol_table {
    CREATE TABLE src(a INTEGER, b AS (a * 2));
    INSERT INTO src(a) VALUES(5), (10);
    CREATE TABLE dst(x INTEGER, y AS (x * 3));
    INSERT INTO dst(x) SELECT b FROM src;
    SELECT x, y FROM dst ORDER BY x;
}
expect {
    10|30
    20|60
}

test gencol_insert_select_virtual_middle {
    CREATE TABLE src(x INTEGER);
    INSERT INTO src VALUES(1), (2), (3);
    CREATE TABLE dst(a INTEGER, v AS (a * 10), c INTEGER DEFAULT 99);
    INSERT INTO dst(a) SELECT x FROM src;
    SELECT a, v, c FROM dst ORDER BY a;
}
expect {
    1|10|99
    2|20|99
    3|30|99
}

test gencol_update_fanout {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c AS (a * 3), d AS (a + 100));
    INSERT INTO t1(a) VALUES(5);
    SELECT a, b, c, d FROM t1;
    UPDATE t1 SET a = 10;
    SELECT a, b, c, d FROM t1;
}
expect {
    5|10|15|105
    10|20|30|110
}

test gencol_update_fanout_multiple_rows {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, a INTEGER, b AS (a * 2), c AS (a + 100));
    INSERT INTO t1(id, a) VALUES(1, 5), (2, 10), (3, 15);
    UPDATE t1 SET a = a + 1;
    SELECT id, a, b, c FROM t1 ORDER BY id;
}
expect {
    1|6|12|106
    2|11|22|111
    3|16|32|116
}

# =============================================================================
# 9. Queries (WHERE, ORDER BY, GROUP BY, JOINs, window functions)
# =============================================================================

test gencol_where_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(1), (2), (3), (4), (5);
    SELECT a FROM t1 WHERE b > 6;
}
expect {
    4
    5
}

test gencol_order_by {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(3), (1), (4), (1), (5);
    SELECT a, b FROM t1 ORDER BY b DESC;
}
expect {
    5|10
    4|8
    3|6
    1|2
    1|2
}

test gencol_group_by_virtual {
    CREATE TABLE t1(a INTEGER, b TEXT, c AS (a * 2) VIRTUAL);
    INSERT INTO t1(a, b) VALUES(1, 'x'), (1, 'y'), (2, 'z'), (3, 'a'), (3, 'b');
    SELECT c, COUNT(*) FROM t1 GROUP BY c ORDER BY c;
}
expect {
    2|2
    4|1
    6|2
}

test gencol_having_count {
    CREATE TABLE t1(a INTEGER, b AS (a % 3) VIRTUAL);
    INSERT INTO t1(a) VALUES(1), (2), (3), (4), (5), (6), (7);
    SELECT b, COUNT(*) FROM t1 GROUP BY b HAVING COUNT(*) >= 3 ORDER BY b;
}
expect {
    1|3
}

test gencol_exists_subquery {
    CREATE TABLE t1(a INTEGER, b TEXT, c AS (LENGTH(b)) VIRTUAL);
    CREATE TABLE t2(x INTEGER);
    INSERT INTO t1(a, b) VALUES(1, 'hi'), (2, 'hello'), (3, 'hey');
    INSERT INTO t2 VALUES(5);
    SELECT a, b, c FROM t1 WHERE EXISTS (SELECT 1 FROM t2 WHERE t2.x = t1.c) ORDER BY a;
}
expect {
    2|hello|5
}

test gencol_cross_join {
    CREATE TABLE t1(a INTEGER, b AS (a * 2) VIRTUAL);
    CREATE TABLE t2(x TEXT);
    INSERT INTO t1(a) VALUES(1), (2);
    INSERT INTO t2 VALUES('a'), ('b');
    SELECT t1.a, t1.b, t2.x FROM t1, t2 ORDER BY t1.a, t2.x;
}
expect {
    1|2|a
    1|2|b
    2|4|a
    2|4|b
}

test gencol_virtual_join {
    CREATE TABLE t1 (a INTEGER, b REAL, c REAL AS (b));
    INSERT INTO t1 VALUES (1, 10.5), (2, 20.5), (3, 30.5);
    CREATE TABLE t2 (x INTEGER, y TEXT);
    INSERT INTO t2 VALUES (1, 'one'), (2, 'two');
    CREATE INDEX idx_c ON t1 (c);
    SELECT t2.x, t1.c FROM t1 INNER JOIN t2 ON (t1.c > 15.0) WHERE t2.x = 1 ORDER BY t2.x, t1.c;
}
expect {
    1|20.5
    1|30.5
}

test gencol_hash_join_virtual_affinity {
    CREATE TABLE t1(a INTEGER, b INTEGER AS (a * 2));
    CREATE TABLE t2(x INTEGER);
    INSERT INTO t1(a) VALUES(1), (2), (3);
    INSERT INTO t2 VALUES(2), (4);
    SELECT t1.a, t1.b, t2.x FROM t1, t2 WHERE t1.b = t2.x ORDER BY t1.a;
}
expect {
    1|2|2
    2|4|4
}

test gencol_window_sum_partition {
    CREATE TABLE t1(a INTEGER, b TEXT, c AS (a % 2) VIRTUAL);
    INSERT INTO t1(a, b) VALUES(1, 'a'), (2, 'b'), (3, 'c'), (4, 'd'), (5, 'e');
    SELECT a, c, SUM(a) OVER (PARTITION BY c ORDER BY a) AS running FROM t1 ORDER BY a;
}
expect {
    1|1|1
    2|0|2
    3|1|4
    4|0|6
    5|1|9
}

test gencol_cte_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    WITH cte AS (SELECT a, b FROM t1 WHERE b > 2) SELECT * FROM cte;
}
expect {
    2|4
    3|6
}

test gencol_view_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 3));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    CREATE VIEW v1 AS SELECT a, b FROM t1;
    SELECT * FROM v1;
}
expect {
    1|3
    2|6
    3|9
}

test gencol_union_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE t2(x INTEGER, y AS (x * 3));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    INSERT INTO t2(x) VALUES(2), (3), (4);
    SELECT b FROM t1 UNION SELECT y FROM t2 ORDER BY 1;
}
expect {
    2
    4
    6
    9
    12
}

test gencol_intersect_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE t2(x INTEGER, y AS (x * 2));
    INSERT INTO t1(a) VALUES(1), (2), (3), (4);
    INSERT INTO t2(x) VALUES(3), (4), (5);
    SELECT b FROM t1 INTERSECT SELECT y FROM t2 ORDER BY 1;
}
expect {
    6
    8
}

test gencol_except_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE t2(x INTEGER, y AS (x * 2));
    INSERT INTO t1(a) VALUES(1), (2), (3), (4);
    INSERT INTO t2(x) VALUES(3), (4), (5);
    SELECT b FROM t1 EXCEPT SELECT y FROM t2 ORDER BY 1;
}
expect {
    2
    4
}

test gencol_distinct_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a % 3));
    INSERT INTO t1(a) VALUES(1), (2), (3), (4), (5), (6);
    SELECT DISTINCT b FROM t1 ORDER BY b;
}
expect {
    0
    1
    2
}

test gencol_limit_offset_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 10));
    INSERT INTO t1(a) VALUES(1), (2), (3), (4), (5);
    SELECT a, b FROM t1 ORDER BY b LIMIT 3 OFFSET 1;
}
expect {
    2|20
    3|30
    4|40
}

test gencol_left_join_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE t2(x INTEGER, y INTEGER);
    INSERT INTO t1(a) VALUES(1), (2), (3);
    INSERT INTO t2(x, y) VALUES(2, 20), (4, 40);
    SELECT t1.a, t1.b, t2.y FROM t1 LEFT JOIN t2 ON t1.a = t2.x ORDER BY t1.a;
}
expect {
    1|2|
    2|4|20
    3|6|
}

test gencol_correlated_subquery_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE t2(x INTEGER, val TEXT);
    INSERT INTO t1(a) VALUES(1), (2), (3), (4);
    INSERT INTO t2(x, val) VALUES(4, 'yes'), (6, 'yes');
    SELECT a, b, (SELECT val FROM t2 WHERE t2.x = t1.b) FROM t1 ORDER BY a;
}
expect {
    1|2|
    2|4|yes
    3|6|yes
    4|8|
}

test gencol_having_multiple_aggregates {
    CREATE TABLE t1(a INTEGER, cat TEXT, b AS (a * 2));
    INSERT INTO t1(a, cat) VALUES(1, 'x'), (2, 'x'), (5, 'y'), (10, 'y'), (15, 'y');
    SELECT cat, SUM(b), AVG(b), MAX(b) FROM t1 GROUP BY cat HAVING SUM(b) > 10 ORDER BY cat;
}
expect {
    y|60|20.0|30
}
expect @js {
    y|60|20|30
}

test gencol_window_functions_multiple {
    CREATE TABLE t1(a INTEGER, grp TEXT, b AS (a * 2));
    INSERT INTO t1(a, grp) VALUES(1, 'A'), (2, 'A'), (3, 'B'), (4, 'B'), (5, 'B');
    SELECT a, b, grp,
           AVG(b) OVER (PARTITION BY grp) as avg_b,
           MIN(b) OVER (PARTITION BY grp) as min_b,
           MAX(b) OVER (PARTITION BY grp) as max_b,
           COUNT(b) OVER (PARTITION BY grp) as cnt_b
    FROM t1 ORDER BY a;
}
expect {
    1|2|A|3.0|2|4|2
    2|4|A|3.0|2|4|2
    3|6|B|8.0|6|10|3
    4|8|B|8.0|6|10|3
    5|10|B|8.0|6|10|3
}
expect @js {
    1|2|A|3|2|4|2
    2|4|A|3|2|4|2
    3|6|B|8|6|10|3
    4|8|B|8|6|10|3
    5|10|B|8|6|10|3
}

test gencol_distinct_virtual_with_base {
    CREATE TABLE t1(a INTEGER, b TEXT, c AS (LENGTH(b)));
    INSERT INTO t1(a, b) VALUES(1, 'hi'), (2, 'hey'), (3, 'hi'), (4, 'hey');
    SELECT DISTINCT c FROM t1 ORDER BY c;
}
expect {
    2
    3
}

test gencol_union_all_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE t2(x INTEGER, y AS (x * 2));
    INSERT INTO t1(a) VALUES(1), (2);
    INSERT INTO t2(x) VALUES(2), (3);
    SELECT b FROM t1 UNION ALL SELECT y FROM t2 ORDER BY 1;
}
expect {
    2
    4
    4
    6
}

test gencol_cte_insert_into_gencol {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    WITH vals(x) AS (VALUES(10), (20), (30))
    INSERT INTO t1(a) SELECT x FROM vals;
    SELECT a, b FROM t1 ORDER BY a;
}
expect {
    10|20
    20|40
    30|60
}

test gencol_offset_past_end {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    SELECT a, b FROM t1 ORDER BY a LIMIT 10 OFFSET 5;
}
expect {
}

test gencol_scalar_subquery_in_select {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE t2(x INTEGER);
    INSERT INTO t1(a) VALUES(5), (10);
    INSERT INTO t2 VALUES(100);
    SELECT a, b, (SELECT x FROM t2) AS sub FROM t1 ORDER BY a;
}
expect {
    5|10|100
    10|20|100
