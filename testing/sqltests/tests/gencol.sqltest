    CREATE INDEX t4_expr_idx ON t4(LOWER(col_a));
    INSERT INTO t4 VALUES ('r1', 'Hello');
    UPDATE t4 SET col_a = 'World' WHERE id = 'r1';
    SELECT count(*) FROM t4 WHERE LOWER(col_a) = 'world';
    PRAGMA integrity_check;
}
expect {
    1
    ok
}

# UPDATE with virtual column depending on multiple base columns
@cross-check-integrity
test update-text-pk-virtual-multi-dep {
    CREATE TABLE t5(id TEXT PRIMARY KEY, a TEXT, b TEXT);
    ALTER TABLE t5 ADD COLUMN v TEXT GENERATED ALWAYS AS (a || '-' || b) VIRTUAL;
    CREATE INDEX t5_v_idx ON t5(v);
    INSERT INTO t5 VALUES ('r1', 'foo', 'bar');
    UPDATE t5 SET a = 'baz' WHERE id = 'r1';
    SELECT count(*) FROM t5 WHERE v = 'baz-bar';
    PRAGMA integrity_check;
}
expect {
    1
    ok
}

# UPDATE with mixed indexes (expression-based + plain) + TEXT PK
@cross-check-integrity
test update-text-pk-mixed-indexes {
    CREATE TABLE t6(id TEXT PRIMARY KEY, col_a TEXT, col_b TEXT);
    ALTER TABLE t6 ADD COLUMN v TEXT GENERATED ALWAYS AS (UPPER(col_a)) VIRTUAL;
    CREATE INDEX t6_v_idx ON t6(v);
    CREATE INDEX t6_b_idx ON t6(col_b);
    INSERT INTO t6 VALUES ('r1', 'hello', 'x');
    UPDATE t6 SET col_a = 'world', col_b = 'y' WHERE id = 'r1';
    PRAGMA integrity_check;
}
expect {
    ok
}

# =============================================================================
# 12. Triggers
# =============================================================================

@requires trigger "needs triggers"
test gencol_trigger_after_insert_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE log(val INTEGER);
    CREATE TRIGGER trg_insert AFTER INSERT ON t1 BEGIN INSERT INTO log VALUES(NEW.b); END;
    INSERT INTO t1(a) VALUES (5);
    SELECT val FROM log;
}
expect {
    10
}

@requires trigger "needs triggers"
test gencol_trigger_virtual_expression {
    CREATE TABLE t1(a INTEGER, b AS (a + 100));
    CREATE TABLE log(val INTEGER);
    CREATE TRIGGER trg_expr AFTER INSERT ON t1 BEGIN INSERT INTO log VALUES(NEW.b + 1); END;
    INSERT INTO t1(a) VALUES (5);
    SELECT val FROM log;
}
expect {
    106
}

@requires trigger "needs triggers"
test gencol_trigger_before_insert_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a + 100));
    CREATE TABLE log(val INTEGER);
    CREATE TRIGGER trg_before BEFORE INSERT ON t1 BEGIN INSERT INTO log VALUES(NEW.b); END;
    INSERT INTO t1(a) VALUES (5);
    SELECT val FROM log;
}
expect {
    105
}

@requires trigger "needs triggers"
test gencol_trigger_after_update_virtual_old_new {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE log(old_val INTEGER, new_val INTEGER);
    CREATE TRIGGER trg_update AFTER UPDATE ON t1 BEGIN INSERT INTO log VALUES(OLD.b, NEW.b); END;
    INSERT INTO t1(a) VALUES (5);
    UPDATE t1 SET a = 10;
    SELECT old_val, new_val FROM log;
}
expect {
    10|20
}

@requires trigger "needs triggers"
test gencol_trigger_when_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE log(val INTEGER);
    CREATE TRIGGER trg_when AFTER INSERT ON t1 WHEN NEW.b > 15 BEGIN INSERT INTO log VALUES(NEW.b); END;
    INSERT INTO t1(a) VALUES (5);
    INSERT INTO t1(a) VALUES (10);
    SELECT val FROM log;
}
expect {
    20
}

@requires trigger "needs triggers"
test gencol_trigger_virtual_chain {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c AS (b + 1));
    CREATE TABLE log(b_val INTEGER, c_val INTEGER);
    CREATE TRIGGER trg_chain AFTER INSERT ON t1 BEGIN INSERT INTO log VALUES(NEW.b, NEW.c); END;
    INSERT INTO t1(a) VALUES (5);
    SELECT b_val, c_val FROM log;
}
expect {
    10|11
}

@requires trigger "needs triggers"
test gencol_trigger_before_update_virtual_new {
    CREATE TABLE t1(a INTEGER, b AS (a * 3));
    CREATE TABLE log(new_val INTEGER);
    CREATE TRIGGER trg_before_upd BEFORE UPDATE ON t1 BEGIN INSERT INTO log VALUES(NEW.b); END;
    INSERT INTO t1(a) VALUES (5);
    UPDATE t1 SET a = 10;
    SELECT new_val FROM log;
}
expect {
    30
}

@requires trigger "needs triggers"
test gencol_trigger_multiple_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c AS (a * 3), d AS (a * 4));
    CREATE TABLE log(b_val INTEGER, c_val INTEGER, d_val INTEGER);
    CREATE TRIGGER trg_multi AFTER INSERT ON t1 BEGIN INSERT INTO log VALUES(NEW.b, NEW.c, NEW.d); END;
    INSERT INTO t1(a) VALUES (5);
    SELECT b_val, c_val, d_val FROM log;
}
expect {
    10|15|20
}

@requires trigger "needs triggers"
test gencol_trigger_for_each_row_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE log(val INTEGER);
    CREATE TRIGGER trg_row AFTER INSERT ON t1 FOR EACH ROW BEGIN INSERT INTO log VALUES(NEW.b); END;
    INSERT INTO t1(a) VALUES (1), (2), (3);
    SELECT val FROM log ORDER BY val;
}
expect {
    2
    4
    6
}

# BEFORE/AFTER trigger NEW values in UPDATE
test gencol_update_trigger_new_values {
    CREATE TABLE t1(a INT, v AS (a*2) VIRTUAL, b INT);
    CREATE TABLE log(op TEXT, old_a INT, old_b INT, new_a INT, new_b INT);
    CREATE TRIGGER trg_before BEFORE UPDATE ON t1 BEGIN INSERT INTO log VALUES('BEFORE', OLD.a, OLD.b, NEW.a, NEW.b); END;
    CREATE TRIGGER trg_after AFTER UPDATE ON t1 BEGIN INSERT INTO log VALUES('AFTER', OLD.a, OLD.b, NEW.a, NEW.b); END;
    INSERT INTO t1(a, b) VALUES(1, 2);
    UPDATE t1 SET a = 10;
    SELECT * FROM log;
}
expect {
    BEFORE|1|2|10|2
    AFTER|1|2|10|2
}

# =============================================================================
# 13. UPSERT
# =============================================================================

test gencol_upsert_virtual {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b * 3));
    INSERT INTO t1(a, b) VALUES (1, 5);
    INSERT INTO t1(a, b) VALUES (1, 10) ON CONFLICT(a) DO UPDATE SET b = excluded.b;
    SELECT a, b, c FROM t1;
}
expect {
    1|10|30
}

test gencol_upsert_virtual_error {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b * 2) VIRTUAL);
    INSERT INTO t1(a, b) VALUES(1, 10);
    INSERT INTO t1(a, b) VALUES(1, 10) ON CONFLICT(a) DO UPDATE SET c = 999;
}
expect error {
    cannot UPDATE generated column
}

test gencol_returning_upsert {
    CREATE TABLE t1(a INT PRIMARY KEY, v AS (a*2) VIRTUAL, b INT);
    INSERT INTO t1(a, b) VALUES(1, 100);
    INSERT INTO t1(a, b) VALUES(1, 200) ON CONFLICT(a) DO UPDATE SET b = excluded.b RETURNING *;
}
expect {
    1|2|200
}

test gencol_upsert_set_current_row {
    CREATE TABLE t1(a INT PRIMARY KEY, v AS (a*2) VIRTUAL, b INT);
    INSERT INTO t1(a, b) VALUES(1, 100);
    INSERT INTO t1(a, b) VALUES(1, 200) ON CONFLICT(a) DO UPDATE SET b = t1.b + excluded.b;
    SELECT * FROM t1;
}
expect {
    1|2|300
}

test gencol_upsert_where_clause {
    CREATE TABLE t1(a INT PRIMARY KEY, v AS (a*2) VIRTUAL, b INT);
    INSERT INTO t1(a, b) VALUES(1, 100);
    INSERT INTO t1(a, b) VALUES(1, 200) ON CONFLICT(a) DO UPDATE SET b = excluded.b WHERE t1.b < 150;
    SELECT * FROM t1;
}
expect {
    1|2|200
}

test gencol_upsert_index_integrity {
    CREATE TABLE t1(a INT PRIMARY KEY, v AS (a*2) VIRTUAL, b INT UNIQUE);
    INSERT INTO t1(a, b) VALUES(1, 100);
    INSERT INTO t1(a, b) VALUES(1, 200) ON CONFLICT(a) DO UPDATE SET b = excluded.b;
    SELECT * FROM t1;
    PRAGMA integrity_check;
}
expect {
    1|2|200
    ok
}

test gencol_upsert_fk_enforcement {
    PRAGMA foreign_keys = ON;
    CREATE TABLE parent(id INT PRIMARY KEY);
    INSERT INTO parent VALUES(1), (2);
    CREATE TABLE child(a INT PRIMARY KEY, v AS (a*10) VIRTUAL, b INT REFERENCES parent(id));
    INSERT INTO child(a, b) VALUES(1, 1);
    INSERT INTO child(a, b) VALUES(1, 999) ON CONFLICT(a) DO UPDATE SET b = excluded.b;
}
expect error {
    FOREIGN KEY constraint failed
}

# UPSERT SET referencing virtual column (should see computed value, not NULL)
test gencol_upsert_set_references_virtual {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b * 10));
    INSERT INTO t1(a, b) VALUES(1, 5);
    INSERT INTO t1(a, b) VALUES(1, 99) ON CONFLICT(a) DO UPDATE SET b = c;
    SELECT a, b, c FROM t1;
}
expect {
    1|50|500
}

@skip "TODO requires https://github.com/tursodatabase/turso/issues/6087"
test gencol_upsert_virtual_before_regular_with_index {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b AS (a * 2) VIRTUAL, c TEXT);
    CREATE INDEX idx_c ON t1(c);
    INSERT INTO t1(a, c) VALUES(1, 'hello');
    INSERT INTO t1(a, c) VALUES(1, 'ignored') ON CONFLICT(a) DO UPDATE SET a = 1;
    SELECT a, b, c FROM t1;
    PRAGMA integrity_check;
}
expect {
    1|2|hello
    ok
}

# =============================================================================
# 14. ALTER TABLE
# =============================================================================

# --- DROP COLUMN with generated columns ---

# Cannot drop column referenced by a virtual column
test gencol_error_drop_column_referenced_virtual {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (a * b));
    ALTER TABLE t1 DROP COLUMN b;
}
expect error {
    error in table t1 after drop column: no such column: b
}

test gencol_error_drop_column_in_function {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (abs(a) + b));
    ALTER TABLE t1 DROP COLUMN a;
}
expect error {
    error in table t1 after drop column: no such column: a
}

# Cannot drop virtual column that another virtual column depends on
test gencol_error_drop_generated_column_with_dependent {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c AS (b + 1));
    ALTER TABLE t1 DROP COLUMN b;
}
expect error {
    error in table t1 after drop column: no such column: b
}

# Can drop a virtual column that has no dependents
test gencol_drop_virtual_column {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c INTEGER);
    INSERT INTO t1(a, c) VALUES(5, 100);
    ALTER TABLE t1 DROP COLUMN b;
    SELECT * FROM t1;
}
expect {
    5|100
}

# Only non-generated column is referenced by virtual column
test gencol_error_drop_column_case_insensitive {
    CREATE TABLE t1(MyColumn INTEGER, b AS (MYCOLUMN * 2));
    ALTER TABLE t1 DROP COLUMN mycolumn;
}
expect error {
    error in table t1 after drop column: must have at least one non-generated column
}

test gencol_error_drop_column_in_case {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (CASE WHEN a > 0 THEN b ELSE 0 END));
    ALTER TABLE t1 DROP COLUMN a;
}
expect error {
    error in table t1 after drop column: no such column: a
}

# Drop non-referenced regular column from table with virtual columns
test gencol_drop_column_with_virtual_present {
    CREATE TABLE t1(a INTEGER, v AS (a * 2) VIRTUAL, b INTEGER);
    INSERT INTO t1(a, b) VALUES (5, 100);
    INSERT INTO t1(a, b) VALUES (10, 200);
    ALTER TABLE t1 DROP COLUMN b;
    SELECT a, v FROM t1;
}
expect {
    5|10
    10|20
}

test gencol_drop_column_with_multiple_virtual {
    CREATE TABLE t1(a INTEGER, v1 AS (a), v2 AS (a * 2), b INTEGER, v3 AS (a * 3));
    INSERT INTO t1(a, b) VALUES (5, 100);
    ALTER TABLE t1 DROP COLUMN b;
    SELECT a, v1, v2, v3 FROM t1;
}
expect {
    5|5|10|15
}

test gencol_drop_column_rebinds_generated_after_preceding_drop {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (b + 1), d INTEGER);
    INSERT INTO t1(a, b, d) VALUES(10, 20, 30);
    ALTER TABLE t1 DROP COLUMN a;
    SELECT b, c, d FROM t1;
}
expect {
    20|21|30
}

# Drop a virtual column, verify remaining data is intact
test gencol_drop_virtual_column_itself {
    CREATE TABLE t1(a INT, b AS (a * 2), c INT);
    INSERT INTO t1(a, c) VALUES(5, 100);
    ALTER TABLE t1 DROP COLUMN b;
    SELECT * FROM t1;
}
expect {
    5|100
}

# Only non-generated column — rejected before dependency check
test gencol_drop_only_regular_column_error {
    CREATE TABLE t1(a INT, b AS (a * 2));
    ALTER TABLE t1 DROP COLUMN a;
}
expect error {
    error in table t1 after drop column: must have at least one non-generated column
}

# Second drop leaves only virtual columns
test gencol_drop_last_non_generated_error {
    CREATE TABLE t1(a INT, b INT, v AS (a * 2));
    ALTER TABLE t1 DROP COLUMN b;
    ALTER TABLE t1 DROP COLUMN a;
}
expect error {
    error in table t1 after drop column: must have at least one non-generated column
}

# --- ADD COLUMN with generated columns ---

test gencol_alter_add_virtual {
    CREATE TABLE t1(a INTEGER);
    INSERT INTO t1 VALUES (5), (10);
    ALTER TABLE t1 ADD COLUMN b AS (a * 2);
    SELECT a, b FROM t1 ORDER BY a;
}
expect {
    5|10
    10|20
}

test gencol_alter_add_virtual_explicit {
    CREATE TABLE t1(a INTEGER);
    INSERT INTO t1 VALUES (3);
    ALTER TABLE t1 ADD COLUMN b AS (a + 100) VIRTUAL;
    SELECT a, b FROM t1;
}
expect {
    3|103
}

test gencol_alter_add_multiple_virtual {
    CREATE TABLE t1(a INTEGER);
    INSERT INTO t1 VALUES (5);
    ALTER TABLE t1 ADD COLUMN b AS (a * 2);
    ALTER TABLE t1 ADD COLUMN c AS (a * 3);
    SELECT a, b, c FROM t1;
}
expect {
    5|10|15
}

test gencol_alter_add_virtual_function {
    CREATE TABLE t1(name TEXT);
    INSERT INTO t1 VALUES ('hello');
    ALTER TABLE t1 ADD COLUMN upper_name AS (UPPER(name));
    SELECT name, upper_name FROM t1;
}
expect {
    hello|HELLO
}

test gencol_alter_add_virtual_complex_expr {
    CREATE TABLE t1(a INTEGER, b INTEGER);
    INSERT INTO t1 VALUES (3, 7);
    ALTER TABLE t1 ADD COLUMN c AS (a + b);
    SELECT a, b, c FROM t1;
}
expect {
    3|7|10
}

# Non-deterministic functions in generated columns are rejected
test gencol_alter_add_virtual_random_error {
    CREATE TABLE t1(a INTEGER);
    ALTER TABLE t1 ADD COLUMN b AS (random()) VIRTUAL;
}
expect error {
    non-deterministic functions prohibited in generated columns
}

test gencol_alter_add_column_generated_pk_rejected {
    CREATE TABLE t1(a INTEGER);
    ALTER TABLE t1 ADD COLUMN b AS (a+1) PRIMARY KEY;
}
expect error {
    (Cannot add a PRIMARY KEY column|generated columns cannot be part of the PRIMARY KEY)
}

@skip "TODO: parser accepts DEFAULT + GENERATED without error"
test gencol_alter_add_column_generated_default_rejected {
    CREATE TABLE t1(a INTEGER);
    ALTER TABLE t1 ADD COLUMN b DEFAULT 5 AS (a+1);
}
expect error {
    (Cannot add a column with non-constant default|error in generated column|cannot have a DEFAULT)
}

# NOT NULL on virtual column validated against existing data
test gencol_alter_add_virtual_not_null_violation {
    CREATE TABLE t1(a, b);
    INSERT INTO t1 VALUES(1, 2), ('null!', NULL), (3, 4);
    ALTER TABLE t1 ADD COLUMN d AS (b + 1) NOT NULL;
}
expect error {
    NOT NULL constraint failed
}

# NOT NULL on virtual column succeeds when all data satisfies it
test gencol_alter_add_virtual_not_null_ok {
    CREATE TABLE t1(a, b);
    INSERT INTO t1 VALUES(1, 2), (3, 4);
    ALTER TABLE t1 ADD COLUMN d AS (b + 1) NOT NULL;
    SELECT a, b, d FROM t1;
}
expect {
    1|2|3
    3|4|5
}

# CHECK constraint validated against existing data
test gencol_alter_add_virtual_check_violation {
    CREATE TABLE t1(a, b);
    INSERT INTO t1 VALUES(1, 2), (3, 4);
    ALTER TABLE t1 ADD COLUMN d AS (b + 1) CHECK(a <> 1);
}
expect error {
    CHECK constraint failed
}

test gencol_alter_add_virtual_check_with_existing_virtual_middle {
    CREATE TABLE t1(a, b AS (a + 1), c);
    INSERT INTO t1(a, c) VALUES(1, 10), (3, 20);
    ALTER TABLE t1 ADD COLUMN d AS (c + 1) CHECK(b < d);
    SELECT a, b, c, d FROM t1 ORDER BY a;
}
expect {
    1|2|10|11
    3|4|20|21
}

test gencol_alter_add_virtual_check_with_existing_virtual_middle_violation {
    CREATE TABLE t1(a, b AS (a + 1), c);
    INSERT INTO t1(a, c) VALUES(1, -2), (3, 20);
    ALTER TABLE t1 ADD COLUMN d AS (c + 1) CHECK(b < d);
}
expect error {
    CHECK constraint failed
}

# INSERT/UPDATE work after ADD COLUMN virtual
test gencol_alter_add_virtual_insert_after {
    CREATE TABLE t1(a INTEGER);
    INSERT INTO t1 VALUES(1);
    ALTER TABLE t1 ADD COLUMN b AS (a * 10);
    INSERT INTO t1(a) VALUES(2);
    SELECT a, b FROM t1 ORDER BY a;
}
expect {
    1|10
    2|20
}

# ADD COLUMN virtual referencing a column added via ADD COLUMN with DEFAULT
# Existing rows have shorter records; validation must use the default, not NULL
test gencol_alter_add_virtual_after_add_default_notnull {
    CREATE TABLE t1(a INTEGER);
    INSERT INTO t1 VALUES(1), (2);
    ALTER TABLE t1 ADD COLUMN b INTEGER DEFAULT 42;
    ALTER TABLE t1 ADD COLUMN c AS (b + 1) NOT NULL;
    SELECT a, b, c FROM t1 ORDER BY a;
}
expect {
    1|42|43
    2|42|43
}

# ADD COLUMN STORED is rejected (SQLite allows STORED, limbo does not)
@skip-if sqlite "limbo does not support STORED generated columns"
test gencol_alter_add_stored_rejected {
    CREATE TABLE t1(a INTEGER);
    ALTER TABLE t1 ADD COLUMN b AS (a * 2) STORED;
}
expect error {
    cannot add a STORED column
}

# --- RENAME COLUMN with generated columns ---

test gencol_rename_column_updates_expression {
    CREATE TABLE t1 (a TEXT, b TEXT AS (a));
    ALTER TABLE t1 RENAME COLUMN a TO c;
    SELECT sql FROM sqlite_master WHERE name='t1';
}
expect {
    CREATE TABLE t1 (c TEXT, b TEXT AS (c))
}

test gencol_rename_column_chain {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c AS (b + a));
    ALTER TABLE t1 RENAME COLUMN a TO x;
    INSERT INTO t1(x) VALUES(5);
    SELECT x, b, c FROM t1;
}
expect {
    5|10|15
}

test gencol_rename_column_middle {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c AS (b + 1));
    ALTER TABLE t1 RENAME COLUMN b TO y;
    INSERT INTO t1(a) VALUES(5);
    SELECT a, y, c FROM t1;
}
expect {
    5|10|11
}

test gencol_rename_column_complex_expr {
    CREATE TABLE t1(a TEXT, b AS (UPPER(a) || '_suffix'));
    ALTER TABLE t1 RENAME COLUMN a TO name;
    INSERT INTO t1(name) VALUES('hello');
    SELECT name, b FROM t1;
}
expect {
    hello|HELLO_suffix
}

test gencol_rename_column_multiple_refs {
    CREATE TABLE t1(a INTEGER, b AS (a + 1), c AS (a * 2), d AS (a - 1));
    ALTER TABLE t1 RENAME COLUMN a TO val;
    INSERT INTO t1(val) VALUES(10);
    SELECT val, b, c, d FROM t1;
}
expect {
    10|11|20|9
}

test gencol_rename_column_case_insensitive {
    CREATE TABLE t1(MyCol INTEGER, b AS (MYCOL * 2));
    ALTER TABLE t1 RENAME COLUMN mycol TO newcol;
    INSERT INTO t1(newcol) VALUES(5);
    SELECT newcol, b FROM t1;
}
expect {
    5|10
}

@skip-if mvcc "Expression indexes are not supported with MVCC"
test gencol_rename_column_with_index_on_generated {
    CREATE TABLE t1 (
        a TEXT,
        b REAL,
        c TEXT AS (a || a)
    );
    INSERT INTO t1 (a, b) VALUES ('test', 1.0);
    CREATE INDEX idx_t1 ON t1 (c DESC, a ASC);
    ALTER TABLE t1 RENAME COLUMN a TO d;
    UPDATE t1 SET b = 2.0, d = 'updated' WHERE b = 1.0;
    SELECT d, b, c FROM t1;
}
expect {
    updated|2.0|updatedupdated
}
expect @js {
    updated|2|updatedupdated
}

# Renaming in one table must not affect generated columns in another table
test gencol_rename_column_other_table_unaffected {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, othername, extra AS (c + 1));
    ALTER TABLE t1 RENAME a to othername;
    SELECT sql FROM sqlite_schema WHERE name = 't2';
}
expect pattern {
    ^CREATE TABLE t2 ?\(c, othername, extra AS \(c \+ 1\)\)$
}

test gencol_rename_column_other_table_matching_name_unaffected {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(a, z AS (a + 1));
    ALTER TABLE t1 RENAME a TO x;
    SELECT sql FROM sqlite_schema WHERE name = 't2';
}
expect pattern {
    ^CREATE TABLE t2 ?\(a, z AS \(a \+ 1\)\)$
}

# =============================================================================
# 15. INTEGER PRIMARY KEY Reference in Generated Columns
# =============================================================================

test gencol_rowid_alias_virtual {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, b AS (id * 2));
    INSERT INTO t1(id) VALUES (5);
    SELECT id, b FROM t1;
}
expect {
    5|10
}

test gencol_rowid_alias_autogenerated {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, b AS (id * 3));
    INSERT INTO t1(id) VALUES (NULL);
    SELECT id, b FROM t1;
}
expect {
    1|3
}

test gencol_rowid_alias_with_other_cols {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, name TEXT, info AS (id || ': ' || name));
    INSERT INTO t1(id, name) VALUES (42, 'Test');
    SELECT info FROM t1;
}
expect {
    42: Test
}

test gencol_rowid_alias_chain {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, b AS (id * 2), c AS (b + id));
    INSERT INTO t1(id) VALUES (5);
    SELECT id, b, c FROM t1;
}
expect {
    5|10|15
}

# Rowid alias PK + only virtual columns is valid
test gencol_pk_plus_only_virtual {
    CREATE TABLE t1(id INTEGER PRIMARY KEY, b AS (id * 2));
    INSERT INTO t1(id) VALUES(5);
    SELECT id, b FROM t1;
}
expect {
    5|10
}

# =============================================================================
# 16. Schema Operations
# =============================================================================

# --- VACUUM ---

@skip "TODO: VACUUM is not supported yet"
test gencol_vacuum_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) VALUES(1), (2), (3), (4), (5);
    DELETE FROM t1 WHERE a IN (2, 4);
    VACUUM;
    SELECT a, b FROM t1;
}
expect {
    1|2
    3|6
    5|10
}

@skip "TODO: VACUUM is not supported yet"
@skip-if mvcc "Expression indexes are not supported with MVCC"
test gencol_vacuum_virtual_with_index {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE INDEX idx1 ON t1(b);
    INSERT INTO t1(a) VALUES(1), (2), (3), (4), (5);
    DELETE FROM t1 WHERE a IN (2, 4);
    VACUUM;
    SELECT a, b FROM t1;
    PRAGMA integrity_check;
}
expect {
    1|2
    3|6
    5|10
    ok
}

# --- PRAGMA table_info hides virtual columns ---

test gencol_pragma_table_info_hides_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c TEXT);
    PRAGMA table_info(t1);
}
expect {
    0|a|INTEGER|0||0
    1|c|TEXT|0||0
}

# =============================================================================
# 17. Edge Cases
# =============================================================================

test gencol_null_concat {
    CREATE TABLE t1(a TEXT, b TEXT, c AS (a || b));
    INSERT INTO t1(a, b) VALUES('hello', NULL), (NULL, 'world'), (NULL, NULL);
    SELECT a, b, c FROM t1;
}
expect {
    hello||
    |world|
    ||
}

test gencol_deep_dependency_chain {
    CREATE TABLE t1(a INTEGER, b AS (a+1), c AS (b+1), d AS (c+1), e AS (d+1), f AS (e+1));
    INSERT INTO t1(a) VALUES(1);
    SELECT a, b, c, d, e, f FROM t1;
}
expect {
    1|2|3|4|5|6
}

test gencol_default_value_with_virtual {
    CREATE TABLE t1(a INTEGER DEFAULT 42, b AS (a * 2));
    INSERT INTO t1 DEFAULT VALUES;
    SELECT a, b FROM t1;
}
expect {
    42|84
}

# --- STRICT tables with virtual columns ---

test gencol_strict_basic {
    CREATE TABLE t1(a INTEGER, b INTEGER AS (a * 2)) STRICT;
    INSERT INTO t1(a) VALUES(5);
    SELECT a, b FROM t1;
}
expect {
    5|10
}

test gencol_strict_type_enforcement {
    CREATE TABLE t1(a INTEGER, b TEXT AS (a || 'x')) STRICT;
    INSERT INTO t1(a) VALUES(5);
    SELECT a, typeof(b), b FROM t1;
}
expect {
    5|text|5x
}

test gencol_strict_insert_type_violation {
    CREATE TABLE t1(a INTEGER, b INTEGER AS (a * 2)) STRICT;
    INSERT INTO t1(a) VALUES('not_a_number');
}
expect error {
    cannot store TEXT value in INTEGER column
}

test gencol_strict_multiple_virtual {
    CREATE TABLE t1(a INTEGER, b INTEGER AS (a * 2), c TEXT AS (a || '!')) STRICT;
    INSERT INTO t1(a) VALUES(7);
    SELECT a, b, c FROM t1;
}
expect {
    7|14|7!
}

# COLLATE on virtual generated columns must be applied in WHERE (#6153)

test gencol_virtual_collate_where_eq {
    CREATE TABLE t1(a TEXT, b TEXT GENERATED ALWAYS AS (a) VIRTUAL COLLATE NOCASE);
    INSERT INTO t1(a) VALUES('Hello'),('HELLO'),('hello');
    SELECT * FROM t1 WHERE b = 'hello';
}
expect {
    Hello|Hello
    HELLO|HELLO
    hello|hello
}

test gencol_virtual_collate_where_in {
    CREATE TABLE t1(a TEXT, b TEXT GENERATED ALWAYS AS (a) VIRTUAL COLLATE NOCASE);
    INSERT INTO t1(a) VALUES('Hello'),('HELLO'),('hello');
    SELECT count(*) FROM t1 WHERE b IN ('hello');
}
expect {
    3
}

test gencol_virtual_collate_where_and {
    CREATE TABLE t2(
        id INTEGER PRIMARY KEY,
        season TEXT,
        scene TEXT GENERATED ALWAYS AS (upper(season)) VIRTUAL COLLATE NOCASE
    );
    INSERT INTO t2(season) VALUES('summer'),('SUMMER');
    SELECT count(*) FROM t2 WHERE scene = 'summer' AND id BETWEEN 1 AND 2;
}
expect {
    2
}

test gencol_virtual_collate_index_eq {
    CREATE TABLE t1(a TEXT, b TEXT GENERATED ALWAYS AS (a) VIRTUAL COLLATE NOCASE);
    CREATE INDEX idx_b ON t1(b);
    INSERT INTO t1(a) VALUES('Hello'),('HELLO'),('hello');
    SELECT * FROM t1 WHERE b = 'hello';
}
expect {
    Hello|Hello
    HELLO|HELLO
    hello|hello
}

test gencol_virtual_collate_index_in {
    CREATE TABLE t1(a TEXT, b TEXT GENERATED ALWAYS AS (a) VIRTUAL COLLATE NOCASE);
    CREATE INDEX idx_b ON t1(b);
    INSERT INTO t1(a) VALUES('Hello'),('HELLO'),('hello'),('World');
    SELECT count(*) FROM t1 WHERE b IN ('hello', 'world');
}
expect {
    4
}

test gencol_virtual_collate_group_by {
    CREATE TABLE t1(a TEXT, b TEXT GENERATED ALWAYS AS (a) VIRTUAL COLLATE NOCASE);
    INSERT INTO t1(a) VALUES('Hello'),('HELLO'),('hello');
    SELECT b, count(*) FROM t1 GROUP BY b;
}
expect {
    Hello|3
}

test gencol_virtual_collate_distinct {
    CREATE TABLE t1(a TEXT, b TEXT GENERATED ALWAYS AS (a) VIRTUAL COLLATE NOCASE);
    INSERT INTO t1(a) VALUES('Hello'),('HELLO'),('hello');
    SELECT DISTINCT b FROM t1;
}
expect {
    Hello
}

# --- Large row counts (100+ rows) ---

test gencol_large_row_count {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) SELECT value FROM generate_series(1, 150);
    SELECT COUNT(*) FROM t1;
    SELECT MIN(b), MAX(b) FROM t1;
    SELECT a, b FROM t1 WHERE a = 100;
}
expect {
    150
    2|300
    100|200
}

test gencol_large_row_update {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) SELECT value FROM generate_series(1, 100);
    UPDATE t1 SET a = a + 1000 WHERE a > 50;
    SELECT COUNT(*) FROM t1 WHERE b > 2000;
}
expect {
    50
}

test gencol_large_row_delete {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    INSERT INTO t1(a) SELECT value FROM generate_series(1, 200);
    DELETE FROM t1 WHERE b > 100;
    SELECT COUNT(*) FROM t1;
}
expect {
    50
}

# =============================================================================
# 18. Error Cases: CREATE TABLE Validation
# =============================================================================

# --- Cannot UPDATE/INSERT generated columns ---

test gencol_error_update_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a) VALUES(5);
    UPDATE t1 SET b = 100;
}
expect error {
    cannot UPDATE generated column
}

test gencol_error_insert_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a*2));
    INSERT INTO t1(a, b) VALUES(5, 10);
}
expect error {
    cannot INSERT into generated column
}

# --- PRIMARY KEY / DEFAULT on generated columns ---

test gencol_error_primary_key_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a*2) PRIMARY KEY);
}
expect error {
    generated column.*cannot be part of the PRIMARY KEY
}

test gencol_error_composite_pk_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), PRIMARY KEY(a, b));
}
expect error {
    generated column.*cannot be part of the PRIMARY KEY
}

test gencol_error_default_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a*2) DEFAULT 0);
}
expect error {
    (cannot have a DEFAULT value|cannot use DEFAULT on a generated column)
}

# --- Self-reference and circular dependencies ---

test gencol_error_self_reference {
    CREATE TABLE t1(a INTEGER, b AS (b+1));
}
expect error {
    (cannot reference itself|generated column loop)
}

test gencol_error_self_reference_case_insensitive {
    CREATE TABLE t1(a INTEGER, B AS (b+1));
}
expect error {
    (cannot reference itself|generated column loop)
}

test gencol_error_circular_reference {
    CREATE TABLE t1(a AS (c*2), b INTEGER, c AS (a*2));
}
expect error {
    (circular dependency|generated column loop)
}

test gencol_error_transitive_circular_reference {
    CREATE TABLE t1(a INTEGER, v1 AS (v3+1) VIRTUAL, v2 AS (v1+1) VIRTUAL, v3 AS (v2+1) VIRTUAL);
}
expect error {
    (circular dependency|generated column loop)
}

# --- Must have at least one non-generated column ---

test gencol_error_all_generated {
    CREATE TABLE t1(a AS (123));
}
expect error {
    (must have at least one non-generated column|must have at least one non-generated column)
}

# --- Rowid aliases not allowed in generated columns ---

test gencol_error_rowid {
    CREATE TABLE t1(a INTEGER, b AS (rowid * 2));
}
expect error {
    no such column: rowid
}

test gencol_error_rowid2 {
    CREATE TABLE t1(a INTEGER, b AS (_rowid_ * 2));
}
expect error {
    no such column: _rowid_
}

test gencol_error_oid {
    CREATE TABLE t1(a INTEGER, b AS (oid * 2));
}
expect error {
    no such column: oid
}

# --- Subqueries prohibited ---

test gencol_error_subquery {
    CREATE TABLE t1(a INT, b INT GENERATED ALWAYS AS ((SELECT 1)));
}
expect error {
    subqueries prohibited in generated columns
}

test gencol_error_in_select {
    CREATE TABLE t2(x INTEGER);
    CREATE TABLE t1(a INTEGER, b AS (a IN (SELECT x FROM t2)));
}
expect error {
    subqueries prohibited in generated columns
}

test gencol_error_exists {
    CREATE TABLE t2(x INTEGER);
    CREATE TABLE t1(a INTEGER, b AS (EXISTS(SELECT 1 FROM t2)));
}
expect error {
    subqueries prohibited in generated columns
}

# --- Aggregates prohibited ---

test gencol_error_aggregate {
    CREATE TABLE t1(a INT, b INT GENERATED ALWAYS AS (sum(a)));
}
expect error {
    (aggregate functions prohibited|misuse of aggregate function)
}

test gencol_error_aggregate_star {
    CREATE TABLE t1(a INTEGER, b AS (count(*)));
}
expect error {
    (aggregate functions prohibited|misuse of aggregate function)
}

# --- Non-deterministic functions prohibited ---

test gencol_error_nondeterministic_virtual {
    CREATE TABLE t1(a INT, b INT GENERATED ALWAYS AS (random()) VIRTUAL);
}
expect error {
    non-deterministic functions prohibited in generated columns
}

# SQLite defers the error to the INSERT for these functions.
test gencol_error_nondeterministic_datetime {
    CREATE TABLE t5(a INT, b TEXT GENERATED ALWAYS AS (datetime('now')));
    INSERT INTO t5 DEFAULT VALUES;
}
expect error {
    non-deterministic
}

test gencol_error_nondeterministic_strftime {
    CREATE TABLE t6(a INT, b TEXT GENERATED ALWAYS AS (strftime('%s','now')));
    INSERT INTO t6 DEFAULT VALUES;
}
expect error {
    non-deterministic
}

test gencol_error_nondeterministic_unixepoch {
    CREATE TABLE t7(a INT, b INT GENERATED ALWAYS AS (unixepoch('now')));
    INSERT INTO t7 DEFAULT VALUES;
}
expect error {
    non-deterministic
}

# --- Dot operator prohibited ---

test gencol_error_dot_operator {
    CREATE TABLE t1(a AS (t1.b), b);
}
expect error {
    the "." operator prohibited in generated columns
}

test gencol_error_doubly_qualified {
    CREATE TABLE t1(a INTEGER, b AS (main.t1.a));
}
expect error {
    the "." operator prohibited in generated columns
}

# --- Window functions prohibited ---

test gencol_error_window_function {
    CREATE TABLE t1(a INTEGER, b AS (sum(a) OVER ()));
}
expect error {
    (window functions prohibited|misuse of window function)
}

test gencol_error_nested_window_function {
    CREATE TABLE t1(a INTEGER, b AS (a + sum(a) OVER ()));
}
expect error {
    (window functions prohibited|misuse of window function)
}

# --- Bind parameters prohibited ---

test gencol_error_bind_parameter {
    CREATE TABLE t1(a INTEGER, b AS (?1 + a));
}
expect error {
    (bind parameters prohibited|parameters prohibited in generated columns)
}

test gencol_error_bind_parameter_unnamed {
    CREATE TABLE t1(a INTEGER, b AS (? + a));
}
expect error {
    (bind parameters prohibited|parameters prohibited in generated columns)
}

# --- Stored generated columns rejected ---

@skip-if sqlite "TODO support stored generated columns"
test gencol_stored_rejected {
    CREATE TABLE t1(a INTEGER, b INTEGER AS (a * 2) STORED);
}
expect error {
    Stored generated columns are not supported
}

@skip-if sqlite "TODO support stored generated columns"
test gencol_stored_generated_always_rejected {
    CREATE TABLE t1(a REAL, b INTEGER GENERATED ALWAYS AS (a) STORED);
}
expect error {
    Stored generated columns are not supported
}

# =============================================================================
# 17. validate_generated_expr Branch Coverage (nested expressions)
# =============================================================================

# --- Nested error cases ---

test gencol_error_nested_subquery_in_func {
    CREATE TABLE t2(x INTEGER);
    CREATE TABLE t1(a INTEGER, b AS (ABS((SELECT x FROM t2))));
}
expect error {
    subqueries prohibited in generated columns
}

test gencol_error_nested_aggregate {
    CREATE TABLE t1(a INTEGER, b AS (a + sum(a)));
}
expect error {
    (aggregate functions prohibited|misuse of aggregate function)
}

test gencol_error_nested_nondeterministic {
    CREATE TABLE t1(a INTEGER, b AS (a + random()));
}
expect error {
    non-deterministic functions prohibited in generated columns
}

test gencol_error_nested_dot_in_case {
    CREATE TABLE t1(a INTEGER, b AS (CASE WHEN a > 0 THEN t1.a ELSE 0 END));
}
expect error {
    the "." operator prohibited in generated columns
}

test gencol_error_nested_subquery_in_case {
    CREATE TABLE t2(x INTEGER);
    CREATE TABLE t1(a INTEGER, b AS (CASE WHEN (SELECT 1 FROM t2) THEN a ELSE 0 END));
}
expect error {
    subqueries prohibited in generated columns
}

test gencol_error_nested_in_select {
    CREATE TABLE t2(x INTEGER);
    CREATE TABLE t1(a INTEGER, b AS (CASE WHEN a IN (SELECT x FROM t2) THEN 1 ELSE 0 END));
}
expect error {
    subqueries prohibited in generated columns
}

test gencol_error_nested_exists_in_arith {
    CREATE TABLE t2(x INTEGER);
    CREATE TABLE t1(a INTEGER, b AS (a + EXISTS(SELECT 1 FROM t2)));
}
expect error {
    subqueries prohibited in generated columns
}

test gencol_error_nested_aggregate_star {
    CREATE TABLE t1(a INTEGER, b AS (a + count(*)));
}
expect error {
    (aggregate functions prohibited|misuse of aggregate function)
}

test gencol_error_nested_doubly_qualified {
    CREATE TABLE t1(a INTEGER, b AS (ABS(main.t1.a)));
}
expect error {
    the "." operator prohibited in generated columns
}

# --- Nested valid expressions ---

test gencol_validate_nested_cast {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (ABS(CAST(a AS REAL)) + b));
    INSERT INTO t1(a, b) VALUES(-5, 3);
    SELECT c FROM t1;
}
expect {
    8.0
}
expect @js {
    8
}

test gencol_validate_nested_isnull {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (CASE WHEN a IS NULL THEN b ELSE a END));
    INSERT INTO t1(a, b) VALUES(NULL, 99), (5, 99);
    SELECT c FROM t1;
}
expect {
    99
    5
}

test gencol_validate_nested_inlist {
    CREATE TABLE t1(a INTEGER, b AS (CASE WHEN a IN (1, 2, 3) THEN 'low' ELSE 'high' END));
    INSERT INTO t1(a) VALUES(2), (10);
    SELECT a, b FROM t1;
}
expect {
    2|low
    10|high
}

test gencol_validate_nested_between {
    CREATE TABLE t1(a INTEGER, b AS ((a BETWEEN 1 AND 10) + 0));
    INSERT INTO t1(a) VALUES(5), (15);
    SELECT a, b FROM t1;
}
expect {
    5|1
    15|0
}

test gencol_validate_nested_like {
    CREATE TABLE t1(a TEXT, b AS (CASE WHEN a LIKE '%hello%' THEN 1 ELSE 0 END));
    INSERT INTO t1(a) VALUES('say hello'), ('goodbye');
    SELECT a, b FROM t1;
}
expect {
    say hello|1
    goodbye|0
}

test gencol_validate_nested_collate {
    CREATE TABLE t1(a TEXT, b TEXT, c AS ((a COLLATE NOCASE) = b));
    INSERT INTO t1(a, b) VALUES('Hello', 'hello'), ('World', 'earth');
    SELECT a, b, c FROM t1;
}
expect {
    Hello|hello|1
    World|earth|0
}

test gencol_validate_nested_like_escape {
    CREATE TABLE t1(a TEXT, b AS (CASE WHEN a LIKE '%!%%' ESCAPE '!' THEN 1 ELSE 0 END));
    INSERT INTO t1(a) VALUES('100%'), ('hello');
    SELECT a, b FROM t1;
}
expect {
    100%|1
    hello|0
}

test gencol_validate_nested_isnull_arith {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (b + (a ISNULL)));
    INSERT INTO t1(a, b) VALUES(NULL, 10), (5, 10);
    SELECT a, b, c FROM t1;
}
expect {
    |10|11
    5|10|10
}

test gencol_validate_nested_notnull_arith {
    CREATE TABLE t1(a INTEGER, b INTEGER, c AS (b + (a NOTNULL)));
    INSERT INTO t1(a, b) VALUES(NULL, 10), (5, 10);
    SELECT a, b, c FROM t1;
}
expect {
    |10|10
    5|10|11
}

test gencol_validate_nested_case_base {
    CREATE TABLE t1(a INTEGER, b AS (10 + CASE a WHEN 1 THEN 100 WHEN 2 THEN 200 ELSE 300 END));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    SELECT a, b FROM t1;
}
expect {
    1|110
    2|210
    3|310
}

# =============================================================================
# Self-join on table with virtual generated columns (#6148)
# =============================================================================

test gencol_self_join_virtual {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b AS (a * 10));
    INSERT INTO t1(a) VALUES(1), (2), (3);
    SELECT a1.a, a1.b, a2.a, a2.b FROM t1 a1 JOIN t1 a2 ON a1.a = a2.a;
}
expect {
    1|10|1|10
    2|20|2|20
    3|30|3|30
}

# =============================================================================
# Three-table INNER JOIN with virtual generated columns (#6151)
# =============================================================================

test gencol_three_table_inner_join {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b + 100));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_a INTEGER);
    CREATE TABLE t3(id INTEGER PRIMARY KEY, t2_id INTEGER);
    INSERT INTO t1 VALUES(1, 10);
    INSERT INTO t1 VALUES(2, 20);
    INSERT INTO t2 VALUES(1, 1);
    INSERT INTO t2 VALUES(2, 2);
    INSERT INTO t3 VALUES(1, 1);
    INSERT INTO t3 VALUES(2, 2);
    SELECT t1.a, t1.b, t1.c, t2.id, t3.id
      FROM t1
      INNER JOIN t2 ON t2.t1_a = t1.a
      INNER JOIN t3 ON t3.t2_id = t2.id;
}
expect {
    1|10|110|1|1
    2|20|120|2|2
}

test gencol_three_table_inner_join_select_gencol {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b + 100));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_a INTEGER);
    CREATE TABLE t3(id INTEGER PRIMARY KEY, t2_id INTEGER);
    INSERT INTO t1 VALUES(1, 10);
    INSERT INTO t1 VALUES(2, 20);
    INSERT INTO t2 VALUES(1, 1);
    INSERT INTO t2 VALUES(2, 2);
    INSERT INTO t3 VALUES(1, 1);
    INSERT INTO t3 VALUES(2, 2);
    SELECT t1.c
      FROM t1
      INNER JOIN t2 ON t2.t1_a = t1.a
      INNER JOIN t3 ON t3.t2_id = t2.id;
}
expect {
    110
    120
}

test gencol_three_table_inner_join_where_gencol {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b + 100));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_a INTEGER);
    CREATE TABLE t3(id INTEGER PRIMARY KEY, t2_id INTEGER);
    INSERT INTO t1 VALUES(1, 10);
    INSERT INTO t1 VALUES(2, 20);
    INSERT INTO t2 VALUES(1, 1);
    INSERT INTO t2 VALUES(2, 2);
    INSERT INTO t3 VALUES(1, 1);
    INSERT INTO t3 VALUES(2, 2);
    SELECT t1.a, t1.c
      FROM t1
      INNER JOIN t2 ON t2.t1_a = t1.a
      INNER JOIN t3 ON t3.t2_id = t2.id
      WHERE t1.c > 115;
}
expect {
    2|120
}

test gencol_four_table_inner_join {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b INTEGER, c AS (b * 2));
    CREATE TABLE t2(id INTEGER PRIMARY KEY, t1_a INTEGER);
    CREATE TABLE t3(id INTEGER PRIMARY KEY, t2_id INTEGER);
    CREATE TABLE t4(id INTEGER PRIMARY KEY, t3_id INTEGER, val TEXT);
    INSERT INTO t1 VALUES(1, 5);
    INSERT INTO t2 VALUES(1, 1);
    INSERT INTO t3 VALUES(1, 1);
    INSERT INTO t4 VALUES(1, 1, 'ok');
    SELECT t1.a, t1.b, t1.c, t4.val
      FROM t1
      INNER JOIN t2 ON t2.t1_a = t1.a
      INNER JOIN t3 ON t3.t2_id = t2.id
      INNER JOIN t4 ON t4.t3_id = t3.id;
}
expect {
    1|5|10|ok
}

# =============================================================================
# DELETE triggers on tables with virtual generated columns (#6150)
# =============================================================================

test gencol_delete_before_trigger_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE log(msg TEXT);
    CREATE TRIGGER tr_before_del BEFORE DELETE ON t1
    BEGIN
        INSERT INTO log VALUES('deleting ' || OLD.a);
    END;
    INSERT INTO t1(a) VALUES(1), (2), (3);
    DELETE FROM t1 WHERE a = 2;
    SELECT * FROM log;
    SELECT a, b FROM t1;
}
expect {
    deleting 2
    1|2
    3|6
}

test gencol_delete_after_trigger_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2));
    CREATE TABLE log(msg TEXT);
    CREATE TRIGGER tr_after_del AFTER DELETE ON t1
    BEGIN
        INSERT INTO log VALUES('deleted ' || OLD.a);
    END;
    INSERT INTO t1(a) VALUES(10), (20);
    DELETE FROM t1;
    SELECT * FROM log;
}
expect {
    deleted 10
    deleted 20
}

test gencol_delete_trigger_ref_virtual_col {
    CREATE TABLE t1(a INTEGER, b AS (a + 100));
    CREATE TABLE log(msg TEXT);
    CREATE TRIGGER tr_del BEFORE DELETE ON t1
    BEGIN
        INSERT INTO log VALUES('old_b=' || OLD.b);
    END;
    INSERT INTO t1(a) VALUES(5);
    DELETE FROM t1 WHERE a = 5;
    SELECT * FROM log;
}
expect {
    old_b=105
}

test gencol_delete_trigger_multiple_virtual {
    CREATE TABLE t1(a INTEGER, b AS (a * 2), c TEXT, d AS (a || c));
    CREATE TABLE log(msg TEXT);
    CREATE TRIGGER tr_del AFTER DELETE ON t1
    BEGIN
        INSERT INTO log VALUES(OLD.a || '|' || OLD.c);
    END;
    INSERT INTO t1(a, c) VALUES(1, 'x'), (2, 'y');
    DELETE FROM t1 WHERE a = 1;
    SELECT * FROM log;
    SELECT a, b, c, d FROM t1;
}
expect {
    1|x
    2|4|y|2y
}

test gencol_upsert_trigger_virtual_col {
    CREATE TABLE t1(a INTEGER PRIMARY KEY, b TEXT, c AS (a || b));
    CREATE TABLE log(msg TEXT);
    CREATE TRIGGER tr AFTER UPDATE ON t1
    BEGIN
        INSERT INTO log VALUES('old_c=' || OLD.c || ' new_c=' || NEW.c);
    END;
    INSERT INTO t1(a, b) VALUES(1, 'x');
    INSERT INTO t1(a, b) VALUES(1, 'y') ON CONFLICT(a) DO UPDATE SET b = excluded.b;
    SELECT * FROM log;
    SELECT a, b, c FROM t1;
}
expect {
    old_c=1x new_c=1y
    1|y|1y
}


# Parent UPDATE with default NO ACTION should fail when gen-col FK changes
@cross-check-integrity
test fk-gencol-unique-idx-update-no-action {
    PRAGMA foreign_keys=ON;
    CREATE TABLE p(a INTEGER, b INTEGER GENERATED ALWAYS AS (a*2) VIRTUAL);
    CREATE UNIQUE INDEX idx_p_b ON p(b);
    CREATE TABLE c(x INTEGER REFERENCES p(b));
    INSERT INTO p(a) VALUES(1);
    INSERT INTO c(x) VALUES(2);
    UPDATE p SET a=3 WHERE a=1;
}
expect error {
}

# ON DELETE CASCADE should remove child rows
@cross-check-integrity
test fk-gencol-unique-idx-delete-cascade {
    PRAGMA foreign_keys=ON;
    CREATE TABLE p(a INTEGER, b INTEGER GENERATED ALWAYS AS (a*2) VIRTUAL);
    CREATE UNIQUE INDEX idx_p_b ON p(b);
    CREATE TABLE c(x INTEGER REFERENCES p(b) ON DELETE CASCADE);
    INSERT INTO p(a) VALUES(10);
    INSERT INTO c(x) VALUES(20);
    DELETE FROM p WHERE a=10;
    SELECT count(*) FROM c;
}
expect {
    0
}

# ON DELETE SET NULL should null-out child FK column
@cross-check-integrity
test fk-gencol-unique-idx-delete-set-null {
    PRAGMA foreign_keys=ON;
    CREATE TABLE p(a INTEGER, b INTEGER GENERATED ALWAYS AS (a*2) VIRTUAL);
    CREATE UNIQUE INDEX idx_p_b ON p(b);
    CREATE TABLE c(x INTEGER REFERENCES p(b) ON DELETE SET NULL);
    INSERT INTO p(a) VALUES(100);
    INSERT INTO c(x) VALUES(200);
    DELETE FROM p WHERE a=100;
    SELECT typeof(x), x FROM c;
}
expect {
    null|
}

# ON UPDATE CASCADE should propagate new generated value
@cross-check-integrity
test fk-gencol-unique-idx-update-cascade {
    PRAGMA foreign_keys=ON;
    CREATE TABLE p(a INTEGER, b INTEGER GENERATED ALWAYS AS (a*2) VIRTUAL);
    CREATE UNIQUE INDEX idx_p_b ON p(b);
    CREATE TABLE c(x INTEGER REFERENCES p(b) ON UPDATE CASCADE);
    INSERT INTO p(a) VALUES(1000);
    INSERT INTO c(x) VALUES(2000);
    UPDATE p SET a=1001 WHERE a=1000;
    SELECT * FROM c;
}
expect {
    2002
}

# DROP TABLE should fail with default NO ACTION when child rows exist
@cross-check-integrity
test fk-gencol-unique-idx-drop-table {
    PRAGMA foreign_keys=ON;
    CREATE TABLE p2(a INTEGER, b INTEGER GENERATED ALWAYS AS (a*2) VIRTUAL);
    CREATE UNIQUE INDEX idx_p2_b ON p2(b);
    CREATE TABLE c5(x INTEGER REFERENCES p2(b));
    INSERT INTO p2(a) VALUES(1);
    INSERT INTO c5(x) VALUES(2);
    DROP TABLE p2;
}
expect error {
}

# Child insert validation should still work (sanity check)
@cross-check-integrity
test fk-gencol-unique-idx-child-insert-reject {
    PRAGMA foreign_keys=ON;
    CREATE TABLE p(a INTEGER, b INTEGER GENERATED ALWAYS AS (a*2) VIRTUAL);
    CREATE UNIQUE INDEX idx_p_b ON p(b);
    CREATE TABLE c(x INTEGER REFERENCES p(b));
    INSERT INTO p(a) VALUES(1);
    INSERT INTO c(x) VALUES(3);
}
expect error {
}

# Virtual column NOT at end of schema -- tests physical column index mapping
@cross-check-integrity
test fk-gencol-unique-idx-mid-schema-delete-cascade {
    PRAGMA foreign_keys=ON;
    CREATE TABLE p(a INTEGER, b INTEGER GENERATED ALWAYS AS (a*2) VIRTUAL, c TEXT);
    CREATE UNIQUE INDEX idx_p_b ON p(b);
    CREATE TABLE c(x INTEGER REFERENCES p(b) ON DELETE CASCADE);
    INSERT INTO p(a, c) VALUES(10, 'hello');
    INSERT INTO c(x) VALUES(20);
    DELETE FROM p WHERE a=10;
    SELECT count(*) FROM c;
}
expect {
    0
}

@cross-check-integrity
test fk-gencol-unique-idx-mid-schema-update-no-action {
    PRAGMA foreign_keys=ON;
    CREATE TABLE p(a INTEGER, b INTEGER GENERATED ALWAYS AS (a*2) VIRTUAL, c TEXT);
    CREATE UNIQUE INDEX idx_p_b ON p(b);
    CREATE TABLE c(x INTEGER REFERENCES p(b));
    INSERT INTO p(a, c) VALUES(1, 'hi');
    INSERT INTO c(x) VALUES(2);
    UPDATE p SET a=3 WHERE a=1;
}
expect error {
}

