@database :memory:

@cross-check-integrity
test pragma-index-list-single-index {
    CREATE TABLE t1(a, b, c);
    CREATE INDEX idx1 ON t1(a);
    PRAGMA index_list('t1');
}
expect {
    0|idx1|0|c|0
}

@cross-check-integrity
test pragma-index-list-equals-syntax {
    CREATE TABLE t1(a, b, c);
    CREATE INDEX idx1 ON t1(a);
    PRAGMA index_list=t1;
}
expect {
    0|idx1|0|c|0
}

@cross-check-integrity
test pragma-index-list-multiple-indexes {
    CREATE TABLE t1(a, b, c);
    CREATE INDEX idx1 ON t1(a);
    CREATE UNIQUE INDEX idx2 ON t1(b, c);
    SELECT name, "unique", origin, partial FROM pragma_index_list('t1') ORDER BY name;
}
expect {
    idx1|0|c|0
    idx2|1|c|0
}

@cross-check-integrity
test pragma-index-list-autoindex-unique {
    CREATE TABLE t1(a, b UNIQUE, c);
    PRAGMA index_list('t1');
}
expect {
    0|sqlite_autoindex_t1_1|1|u|0
}

@cross-check-integrity
test pragma-index-list-autoindex-pk {
    CREATE TABLE t1(a PRIMARY KEY, b, c);
    PRAGMA index_list('t1');
}
expect {
    0|sqlite_autoindex_t1_1|1|pk|0
}

@cross-check-integrity
test pragma-index-list-mixed-origins {
    CREATE TABLE t1(a PRIMARY KEY, b UNIQUE, c);
    CREATE INDEX idx1 ON t1(c);
    SELECT name, "unique", origin, partial FROM pragma_index_list('t1') ORDER BY name;
}
expect {
    idx1|0|c|0
    sqlite_autoindex_t1_1|1|pk|0
    sqlite_autoindex_t1_2|1|u|0
}

@cross-check-integrity
test pragma-index-list-partial-index {
    CREATE TABLE t1(a, b, c);
    CREATE INDEX idx_partial ON t1(a) WHERE b > 0;
    PRAGMA index_list('t1');
}
expect {
    0|idx_partial|0|c|1
}

@cross-check-integrity
test pragma-index-list-no-indexes {
    CREATE TABLE t1(a, b, c);
    PRAGMA index_list('t1');
}
expect {
}

test pragma-index-list-nonexistent-table {
    PRAGMA index_list('nonexistent');
}
expect {
}

@cross-check-integrity
test pragma-index-list-prefers-temp-shadowed-table {
    CREATE TABLE t(a INTEGER);
    CREATE INDEX main_idx ON t(a);
    CREATE TEMP TABLE t(a INTEGER);
    CREATE INDEX temp_idx ON t(a);
    PRAGMA index_list('t');
}
expect {
    0|temp_idx|0|c|0
}

@cross-check-integrity
test pragma-index-info-prefers-temp-shadowed-name {
    CREATE TABLE t(a INTEGER, b INTEGER);
    CREATE INDEX dup_idx ON t(a);
    CREATE TEMP TABLE t(a INTEGER, b INTEGER);
    CREATE INDEX dup_idx ON t(b);
    PRAGMA index_info('dup_idx');
}
expect {
    0|1|b
}

@cross-check-integrity
test pragma-index-xinfo-prefers-temp-shadowed-name {
    CREATE TABLE t(a INTEGER, b INTEGER);
    CREATE INDEX dup_idx ON t(a);
    CREATE TEMP TABLE t(a INTEGER, b INTEGER);
    CREATE INDEX dup_idx ON t(b);
    PRAGMA index_xinfo('dup_idx');
}
expect {
    0|1|b|0|BINARY|1
    1|-1||0|BINARY|0
}

@cross-check-integrity
test pragma-index-list-function-syntax {
    CREATE TABLE t1(a, b, c);
    CREATE INDEX idx1 ON t1(a);
    SELECT * FROM pragma_index_list('t1');
}
expect {
    0|idx1|0|c|0
}

@skip-if mvcc "attach is not supported for mvcc"
@cross-check-integrity
test pragma-index-list-attached-database {
    ATTACH ':memory:' AS aux;
    CREATE TABLE aux.t1(a, b, c);
    CREATE INDEX aux.idx1 ON t1(a);
    PRAGMA aux.index_list('t1');
    PRAGMA aux.index_info('idx1');
}
expect {
    0|idx1|0|c|0
    0|0|a
}

@cross-check-integrity
test pragma-index-info-explicit-main-vs-temp {
    CREATE TABLE t(a INTEGER, b INTEGER);
    CREATE INDEX dup_idx ON t(a);
    CREATE TEMP TABLE t(a INTEGER, b INTEGER);
    CREATE INDEX dup_idx ON t(b);
    PRAGMA main.index_info('dup_idx');
    PRAGMA temp.index_info('dup_idx');
}
expect {
    0|0|a
    0|1|b
}
