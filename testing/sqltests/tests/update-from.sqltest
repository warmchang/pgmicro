    INSERT INTO s1 VALUES(1,'s1');
    INSERT INTO s2 VALUES(1,'s2');
    INSERT INTO s3 VALUES(1,'s3');
    UPDATE t1 SET b = s1.y FROM s1 NATURAL JOIN s2 NATURAL JOIN s3 WHERE s1.x = t1.a;
    SELECT * FROM t1;
}
