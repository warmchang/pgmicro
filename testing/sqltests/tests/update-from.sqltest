    INSERT INTO t2 VALUES(1,'X'),(2,'Y'),(3,'Z');
    UPDATE t1 SET b = sub.val
    FROM (SELECT id, val FROM t2 ORDER BY id LIMIT 2) AS sub
    WHERE sub.id = t1.a;
