    INSERT INTO t2 VALUES(1,'X'),(2,'Y'),(3,'Z');
    UPDATE t1 SET b = CASE WHEN t2.val = 'X' THEN 'matched_x' WHEN t2.val = 'Y' THEN 'matched_y' ELSE 'other' END
    FROM t2 WHERE t2.id = t1.a;
