    INSERT INTO t1 VALUES(1,0),(2,0),(3,0);
    INSERT INTO t2 VALUES(1, 3.0);
    INSERT INTO t2 VALUES(2, 3.5);
    INSERT INTO t2 VALUES(3, '42');
    UPDATE t1 SET b = t2.val FROM t2 WHERE t2.id = t1.a;
    SELECT a, b, typeof(b) FROM t1 ORDER BY a;
