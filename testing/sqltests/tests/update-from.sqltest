    INSERT INTO t1 VALUES(1,'orig');
    INSERT INTO t2 VALUES(1,'X1');
    INSERT INTO t3 VALUES(1,'Y1'),(2,'Y2');
    UPDATE t1 SET b = COALESCE(t2.x, '') || COALESCE(t3.y, '')
    FROM t2 LEFT JOIN t3 ON t2.id = t3.id WHERE t2.id = t1.a;
    SELECT * FROM t1;
