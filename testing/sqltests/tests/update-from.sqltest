    INSERT INTO t2 VALUES(1,10,'X'),(2,20,'Y');
    INSERT INTO t3 VALUES(1,10,'E1'),(2,20,'E2');
    UPDATE t1 SET b = t2.val || t3.extra FROM t2 JOIN t3 USING(x, y) WHERE t2.x = t1.a;
