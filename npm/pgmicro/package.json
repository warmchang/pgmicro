{
  "name": "pg-micro",
  "version": "0.0.2",
  "description": "pgmicro — a PostgreSQL-compatible embeddable database",
  "repository": {
    "type": "git",
    "url": "https://github.com/glommer/pgmicro"
  },
  "license": "MIT",
  "module": "./dist/promise.js",
